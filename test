# TASK WRAPPER — Fixed race condition
# is_busy stays True until the submitted task
# actually finishes (via done_callback).
# ─────────────────────────────────────────────
def task_wrapper(request, config, payload, df):
    """
    Submits mrmg_execute_vr to the thread pool.
    is_busy is set True before submit and only
    cleared in the done_callback after the future
    completes (success or failure).
    """
    global is_busy
    is_busy.value = True
    logger.info("TASK_WRAPPER: Task submitted, is_busy=True")

    def done_callback(future):
        is_busy.value = False
        exc = future.exception()
        if exc:
            logger.error(f"TASK_WRAPPER: Task failed with exception: {exc}")
        else:
            logger.info("TASK_WRAPPER: Task completed successfully, is_busy=False")

    try:
        future = executor.submit(mrmg_execute_vr, request, config, payload, df)
        future.add_done_callback(done_callback)
    except Exception as e:
        # If submit itself fails, release the lock immediately
        is_busy.value = False
        logger.error(f"TASK_WRAPPER: Failed to submit task: {e}")
        raise


