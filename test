    # ------------------------------------------------------------------
    # Paste purely as plain text, safely rebuild tables, and bold headings
    # ------------------------------------------------------------------

    def paste_content_text_only(self, content, after, index):
        """
        Safely extracts raw text. Rebuilds tables to preserve layout.
        Detects if a source paragraph was a heading/subheading and 
        applies standard bold formatting to the new clean text.
        """
        self.move_cursor(to=after)
        if self._cursor is None:
            return

        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')

        for c in content['data']:
            
            # ==========================================
            # SCENARIO 1: IT IS A TABLE
            # ==========================================
            if c.tag == f'{{{w}}}tbl':
                new_tbl = etree.Element(f'{{{w}}}tbl')
                
                borders_xml = (
                    f'<w:tblPr xmlns:w="{w}">'
                    f'<w:tblBorders>'
                    f'<w:top w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'<w:left w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'<w:bottom w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'<w:right w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'<w:insideH w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'<w:insideV w:val="single" w:sz="4" w:space="0" w:color="auto"/>'
                    f'</w:tblBorders>'
                    f'</w:tblPr>'
                )
                new_tbl.append(etree.fromstring(borders_xml))

                for row in c.findall(f'.//{{{w}}}tr'):
                    new_row = etree.Element(f'{{{w}}}tr')
                    
                    for cell in row.findall(f'.//{{{w}}}tc'):
                        new_cell = etree.Element(f'{{{w}}}tc')
                        paras = cell.findall(f'.//{{{w}}}p')
                        
                        if not paras:
                            new_cell.append(etree.fromstring(f'<w:p xmlns:w="{w}"/>'))
                        else:
                            for p in paras:
                                raw_text = "".join(p.itertext())
                                if not raw_text.strip():
                                    continue
                                
                                safe_text = escape(raw_text)
                                
                                # Check if it's a heading inside the table
                                is_heading = False
                                p_style = p.find(f'.//{{{w}}}pStyle')
                                if p_style is not None and 'heading' in p_style.get(f'{{{w}}}val', '').lower():
                                    is_heading = True
                                
                                bold_tag = '<w:rPr><w:b/></w:rPr>' if is_heading else ''
                                
                                p_xml = (
                                    f'<w:p xmlns:w="{w}">'
                                    f'<w:r>'
                                    f'{bold_tag}'
                                    f'<w:t xml:space="preserve">{safe_text}</w:t>'
                                    f'</w:r>'
                                    f'</w:p>'
                                )
                                new_cell.append(etree.fromstring(p_xml))
                                
                        new_row.append(new_cell)
                
                    new_tbl.append(new_row)
                
                self._cursor.addnext(new_tbl)
                self._cursor = new_tbl

            # ==========================================
            # SCENARIO 2: IT IS A REGULAR PARAGRAPH
            # ==========================================
            else:
                raw_text = "".join(c.itertext())
                if not raw_text.strip():
                    continue

                safe_text = escape(raw_text)
                
                # Check if the original paragraph was a heading
                is_heading = False
                p_style = c.find(f'.//{{{w}}}pStyle')
                if p_style is not None and 'heading' in p_style.get(f'{{{w}}}val', '').lower():
                    is_heading = True
                
                # If it's a heading, inject the bold run property (<w:b/>)
                bold_tag = '<w:rPr><w:b/></w:rPr>' if is_heading else ''
                
                elem_xml = (
                    f'<w:p xmlns:w="{w}">'
                    f'<w:r>'
                    f'{bold_tag}'
                    f'<w:t xml:space="preserve">{safe_text}</w:t>'
                    f'</w:r>'
                    f'</w:p>'
                )
                new_para = etree.fromstring(elem_xml)

                self._cursor.addnext(new_para)
                self._cursor = new_para 

        # Save the finalized document.xml
        etree.ElementTree(self._doc).write(
            os.path.join(self._path, 'word', 'document.xml'),
            **_XML_WRITE_KWARGS,
        )
