Your current code already merges rows by section, but the issue is it only merges **consecutive** rows with the same section. If the same section appears in non-consecutive rows, they won't be merged.

Here's the fixed version that merges **all rows for the same section** regardless of position:

```python
import pandas as pd
import numpy as np

def merge_sections(
    df,
    section_col="section_name",
    text_col="paragraph_content",
    content_col="content",
    max_nan_words=1000
):
    def to_list(x):
        if x is None:
            return []
        if pd.isna(x) if not isinstance(x, (list, tuple, dict)) else False:
            return []
        if isinstance(x, list):
            return x
        if isinstance(x, tuple):
            return [x]
        return [x]

    def safe_text(x):
        if x is None or (not isinstance(x, (list, tuple)) and pd.isna(x)):
            return ""
        return str(x)

    # ── Separate named sections vs NaN sections ────────────────────────────
    nan_mask = df[section_col].isna()
    named_df = df[~nan_mask].copy()
    nan_df   = df[nan_mask].copy()

    merged_rows = []

    # ── 1. Merge all rows with the same section name into one row ──────────
    for section_name, group in named_df.groupby(section_col, sort=False):
        first_row = group.iloc[0].copy()

        # Combine all text
        all_text = " ".join(
            safe_text(t) for t in group[text_col] if safe_text(t)
        ).strip()
        first_row[text_col] = all_text

        # Combine all content lists
        combined_content = []
        for c in group[content_col]:
            combined_content.extend(to_list(c))
        first_row[content_col] = combined_content

        merged_rows.append(first_row)

    named_merged = pd.DataFrame(merged_rows)

    # ── 2. Handle NaN sections — chunk by max_nan_words ───────────────────
    nan_rows = []
    current_row = None
    current_nan_words = 0

    for _, row in nan_df.iterrows():
        text = safe_text(row.get(text_col, ""))
        row_words = len(text.split())

        if current_row is None:
            current_row = row.copy()
            current_row[content_col] = to_list(current_row[content_col])
            current_nan_words = row_words
            continue

        if current_nan_words + row_words <= max_nan_words:
            current_row[text_col] = (safe_text(current_row[text_col]) + " " + text).strip()
            current_row[content_col].extend(to_list(row[content_col]))
            current_nan_words += row_words
        else:
            nan_rows.append(current_row)
            current_row = row.copy()
            current_row[content_col] = to_list(current_row[content_col])
            current_nan_words = row_words

    if current_row is not None:
        nan_rows.append(current_row)

    nan_merged = pd.DataFrame(nan_rows) if nan_rows else pd.DataFrame(columns=df.columns)

    # ── 3. Combine and restore original section order ──────────────────────
    doc_df = pd.concat([named_merged, nan_merged], ignore_index=True)

    return doc_df


doc_df = merge_sections(df)
print(f"Original rows : {len(df)}")
print(f"Merged rows   : {len(doc_df)}")
print(doc_df[[" section_name", "paragraph_content"]].head(20))
```

Key changes vs your original:

| | Original | Fixed |
|---|---|---|
| Merge strategy | Consecutive rows only | All rows per section globally |
| Named sections | `groupby` on consecutive | `groupby` across entire df |
| NaN sections | Mixed in main loop | Handled separately with word limit |
| Result order | Insertion order | Named sections first, then NaN chunks |

