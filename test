# ─────────────────────────────────────────────
# 2.  EXTRACT ENTITIES & RELATIONSHIPS via LLM
# ─────────────────────────────────────────────
def extract_triplets(text: str, llm: ChatOpenAI) -> List[Tuple[str, str, str]]:
    """
    Ask the LLM to return (subject, predicate, object) triplets as JSON.
    Returns a list of (subject, predicate, object) tuples.
    """
    prompt = f"""Extract knowledge graph triplets from the text below.
Return ONLY a JSON array of arrays, each inner array being [subject, predicate, object].
No explanation, no markdown, just raw JSON.

Text:
{text}

Example output:
[["Albert Einstein","developed","theory of relativity"],["Einstein","born in","Ulm"]]
"""
    response = llm.invoke(prompt)
    raw = response.content.strip()

    # Strip markdown fences if present
    raw = re.sub(r"^```(?:json)?|```$", "", raw, flags=re.MULTILINE).strip()

    try:
        data = json.loads(raw)
        return [(str(t[0]), str(t[1]), str(t[2])) for t in data if len(t) == 3]
    except json.JSONDecodeError:
        print(f"[WARN] Could not parse LLM output: {raw[:200]}")
        return []


# ─────────────────────────────────────────────
# 3.  BUILD KNOWLEDGE GRAPH
# ─────────────────────────────────────────────
def build_knowledge_graph(
    documents: List[Document], llm: ChatOpenAI
) -> Tuple[nx.DiGraph, List[Tuple]]:
    """
    Iterates over LangChain Documents, extracts triplets, builds a DiGraph.
    Returns the graph and the flat list of all triplets.
    """
    G = nx.DiGraph()
    all_triplets: List[Tuple[str, str, str]] = []

    for i, doc in enumerate(documents):
        print(f"Processing document {i+1}/{len(documents)} ...")
        triplets = extract_triplets(doc.page_content, llm)
        for subj, pred, obj in triplets:
            G.add_node(subj, type="entity")
            G.add_node(obj, type="entity")
            G.add_edge(subj, obj, relation=pred, source=doc.metadata.get("source", "unknown"))
            all_triplets.append((subj, pred, obj))

    print(f"\nGraph built: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges")
    return G, all_triplets


# ─────────────────────────────────────────────
# 4.  STORE INTO FAISS
#     Each triplet becomes a Document whose
#     page_content is  "subject | predicate | object"
# ─────────────────────────────────────────────
def store_graph_in_faiss(
    triplets: List[Tuple[str, str, str]],
    original_docs: List[Document],
    embeddings: OpenAIEmbeddings,
    faiss_index_path: str = "faiss_kg_index",
) -> FAISS:
    """
    Creates two sets of Documents for FAISS:
      - Triplet documents  (structured knowledge)
      - Original chunk documents  (raw page_content)
    """
    # --- triplet documents ---
    triplet_docs = [
        Document(
            page_content=f"{s} | {p} | {o}",
            metadata={"type": "triplet", "subject": s, "predicate": p, "object": o},
        )
        for s, p, o in triplets
    ]

    # --- chunk original docs for richer retrieval ---
    splitter = RecursiveCharacterTextSplitter(chunk_size=300, chunk_overlap=50)
    chunk_docs = splitter.split_documents(original_docs)
    for d in chunk_docs:
        d.metadata["type"] = "chunk"

    all_docs = triplet_docs + chunk_docs
    print(f"\nIndexing {len(all_docs)} documents into FAISS ...")

    vectorstore = FAISS.from_documents(all_docs, embeddings)
    vectorstore.save_local(faiss_index_path)
    print(f"FAISS index saved to '{faiss_index_path}/'")
    return vectorstore


# ─────────────────────────────────────────────
# 5.  QUERY HELPER
# ─────────────────────────────────────────────
def query_knowledge_base(
    query: str,
    vectorstore: FAISS,
    k: int = 5,
) -> List[Document]:
    results = vectorstore.similarity_search(query, k=k)
    print(f"\nTop {k} results for: '{query}'")
    for i, doc in enumerate(results, 1):
        print(f"  [{i}] ({doc.metadata.get('type','?')}) {doc.page_content}")
    return results


# ─────────────────────────────────────────────
# 6.  VISUALISE GRAPH
# ─────────────────────────────────────────────
def visualise_graph(G: nx.DiGraph, output_path: str = "knowledge_graph.png") -> None:
    plt.figure(figsize=(14, 9))
    pos = nx.spring_layout(G, seed=42, k=2)

    nx.draw_networkx_nodes(G, pos, node_color="#4A90D9", node_size=1800, alpha=0.9)
    nx.draw_networkx_labels(G, pos, font_size=9, font_color="white", font_weight="bold")
    nx.draw_networkx_edges(G, pos, edge_color="#888", arrows=True, arrowsize=20, width=1.5)

    edge_labels = {(u, v): d["relation"] for u, v, d in G.edges(data=True)}
    nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels, font_size=7, font_color="#333")

    plt.title("Knowledge Graph", fontsize=16, fontweight="bold")
    plt.axis("off")
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()
    print(f"Graph visualisation saved to '{output_path}'")


# ─────────────────────────────────────────────
# 7.  SAVE / LOAD GRAPH
# ─────────────────────────────────────────────
def save_graph(G: nx.DiGraph, path: str = "knowledge_graph.pkl") -> None:
    with open(path, "wb") as f:
        pickle.dump(G, f)
    print(f"Graph saved to '{path}'")


def load_graph(path: str = "knowledge_graph.pkl") -> nx.DiGraph:
    with open(path, "rb") as f:
        return pickle.load(f)


def load_faiss(path: str, embeddings: OpenAIEmbeddings) -> FAISS:
    return FAISS.load_local(path, embeddings, allow_dangerous_deserialization=True)


# ─────────────────────────────────────────────
# 8.  MAIN
# ─────────────────────────────────────────────
def main():
    # --- init models ---
    # Set your key: export OPENAI_API_KEY=sk-...
    # Or swap OpenAIEmbeddings/ChatOpenAI for any LangChain-compatible provider.
    embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
    llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

    # --- load documents ---
    documents: List[Document] = get_sample_documents()
    # To use your own loader, e.g.:
    # from langchain_community.document_loaders import PyPDFLoader
    # loader = PyPDFLoader("your_file.pdf")
    # documents = loader.load()

    # --- build graph ---
    graph, triplets = build_knowledge_graph(documents, llm)

    # --- persist graph ---
    save_graph(graph)
    visualise_graph(graph)

    # --- store in FAISS ---
    vectorstore = store_graph_in_faiss(triplets, documents, embeddings)

    # --- sample query ---
    query_knowledge_base("Who developed the theory of relativity?", vectorstore)
    query_knowledge_base("Newton's contributions to physics", vectorstore)


if __name__ == "__main__":
    main()
