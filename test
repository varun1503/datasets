# 🔍 Main Section Finder
# =========================
def find_section(self, to):

    input_section = extract_section_number(to)
    input_title = clean_text(remove_section_number(to))

    best_match = None
    best_text = None
    best_score = 0

    for xx in self._doc.xpath('./w:body/w:p', namespaces=self._doc.nsmap):

        # 🔥 STEP 1: Get raw text WITHOUT numbering (for reset logic)
        temp_text = ''.join([
            x.text for x in xx.xpath('.//w:t', namespaces=self._doc.nsmap) if x.text
        ]).strip()

        # 🔥 STEP 2: Reset tracker BEFORE numbering
        if re.match(r'^1\.?\s+', temp_text):
            print("🔄 Resetting numbering tracker")
            tracker.reset()

        # 🔥 STEP 3: Get processed text ONCE
        raw_text = get_text(xx, self._doc.nsmap)

        if not raw_text:
            continue

        # 🔥 STEP 4: Skip unwanted outline levels
        olvl = self.get_outline_level(xx)
        if olvl in (-1, 9):
            continue

        doc_section = extract_section_number(raw_text)
        doc_title = clean_text(remove_section_number(raw_text))

        # ✅ EXACT MATCH
        if input_section and doc_section and input_section == doc_section:
            print("✅ Exact match found")
            self._cursor = xx
            return raw_text

        # ✅ FUZZY MATCH
        score = fuzz.token_set_ratio(input_title, doc_title)

        if input_section and doc_section:
            if input_section in doc_section or doc_section in input_section:
                score += 10
        elif input_section and not doc_section:
            score += 5

        if score > best_score:
            best_score = score
            best_match = xx
            best_text = raw_text

    # 🔥 FINAL RESULT
    if best_match is not None and best_score >= 85:
        print("✅ Best match selected")
        print("SECTION:", best_text)
        print("SCORE:", best_score)

        self._cursor = best_match
        return best_text

    print("❌ No matching section found")
    return ""
