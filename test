# Standard kwargs for writing XML without breaking Word's formatting
_XML_WRITE_KWARGS = {
    'encoding': 'UTF-8',
    'xml_declaration': True,
    'standalone': 'yes'
}

def copy_file(src, dst):
    """Helper function to copy media files and create directories if needed."""
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    shutil.copyfile(src, dst)

