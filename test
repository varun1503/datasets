    # ------------------------------------------------------------------
    # HELPER 3: Remap Media Relationship IDs
    # ------------------------------------------------------------------
    def _remap_media_ids(self, element, index):
        """
        Prevents corruption by updating the internal relationship IDs of 
        images and charts to match the new unique IDs generated for this document.
        Uses a hardcoded safe_namespaces dictionary to prevent XPathEvalError.
        """
        r_ns = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
        
        # Explicitly define the namespaces so lxml never gets confused
        safe_namespaces = {
            'a': 'http://schemas.openxmlformats.org/drawingml/2006/main',
            'c': 'http://schemas.openxmlformats.org/drawingml/2006/chart',
            'v': 'urn:schemas-microsoft-com:vml'
        }

        # 1. Update modern images (<a:blip r:embed="rIdX">)
        for blip in element.xpath('.//a:blip', namespaces=safe_namespaces):
            old_id = blip.get(f'{{{r_ns}}}embed')
            if old_id:
                blip.set(f'{{{r_ns}}}embed', f"{old_id}c{index}")
                
        # 2. Update Charts (<c:chart r:id="rIdX">)
        for chart in element.xpath('.//c:chart', namespaces=safe_namespaces):
            old_id = chart.get(f'{{{r_ns}}}id')
            if old_id:
                chart.set(f'{{{r_ns}}}id', f"{old_id}c{index}")

        # 3. Update VML shapes/older images (<v:imagedata r:id="rIdX">)
        for img in element.xpath('.//v:imagedata', namespaces=safe_namespaces):
            old_id = img.get(f'{{{r_ns}}}id')
            if old_id:
                img.set(f'{{{r_ns}}}id', f"{old_id}c{index}")
                
        return element
