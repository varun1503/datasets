```python
import logging

class GreenFormatter(logging.Formatter):
    
    FORMATS = {
        logging.DEBUG:    f"\033[92m%(levelname)s:%(name)s:%(message)s\033[0m",
        logging.INFO:     f"\033[92m\033[1m%(levelname)s:%(name)s:%(message)s\033[0m",
        logging.WARNING:  f"\033[42m\033[1m%(levelname)s:%(name)s:%(message)s\033[0m",
        logging.ERROR:    f"\033[42m\033[1m%(levelname)s:%(name)s:%(message)s\033[0m",
        logging.CRITICAL: f"\033[42m\033[1m\033[4m%(levelname)s:%(name)s:%(message)s\033[0m",
    }

    def format(self, record):
        fmt = self.FORMATS.get(record.levelno, self.FORMATS[logging.DEBUG])
        formatter = logging.Formatter(fmt)
        return formatter.format(record)

# Apply to root logger
handler = logging.StreamHandler()
handler.setFormatter(GreenFormatter())
logging.root.handlers = [handler]
logging.root.setLevel(logging.DEBUG)
