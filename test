The issue is `Repair=False` is too strict and the exception catching is too broad. Let me fix it to accurately detect only truly corrupt files:

```python
import os
import win32com.client
import pythoncom
from datetime import datetime


# ─────────────────────────────────────────────────────────────
# ACCURATE WORD OPEN VALIDATOR
# Uses Word's own RepairDocument flag to detect real corruption
# ─────────────────────────────────────────────────────────────

def try_open_in_word(filepath, timeout=30):
    """
    Returns:
        (True,  "OK")          → file opens cleanly
        (False, reason)        → file is genuinely corrupt
        (None,  reason)        → Word not available / other error
    """
    filepath = os.path.abspath(filepath)

    if not os.path.exists(filepath):
        return False, "File not found"

    pythoncom.CoInitialize()
    word = None
    doc  = None

    try:
        word                = win32com.client.Dispatch('Word.Application')
        word.Visible        = False
        word.DisplayAlerts  = 0    # suppress ALL dialogs silently

        # ── Open normally — let Word repair if needed ─────────
        doc = word.Documents.Open(
            filepath,
            ConfirmConversions = False,
            ReadOnly           = True,
            AddToRecentFiles   = False,
            # NO Repair=False here — let Word open it naturally
        )

        # ── Check if Word flagged it as repaired ──────────────
        # doc.Repaired is True only if Word had to fix corruption
        was_repaired = False
        try:
            was_repaired = bool(doc.Repaired)
        except Exception:
            pass  # older Word versions don't have .Repaired

        if was_repaired:
            return False, "Word had to repair the file — content was corrupt"

        # ── Force full document parse ─────────────────────────
        try:
            page_count = doc.ComputeStatistics(2)  # 2 = wdStatisticPages
            word_count = doc.ComputeStatistics(0)  # 0 = wdStatisticWords
        except Exception:
            page_count = 0
            word_count = 0

        return True, f"OK — {page_count} pages, {word_count} words"

    except Exception as e:
        err = str(e).lower()

        # ── Only flag as corrupt for genuine Word errors ───────
        # These are the EXACT COM error codes Word throws
        # for truly unreadable files
        corrupt_signals = [
            'the document is corrupt',
            'unreadable content',
            'cannot open the file',
            'file is corrupt',
            'not a valid',
            'bad zip',
            '-2147467259',   # COM error: unspecified error (bad file)
            '-2146822750',   # COM error: Word file corrupt
            '-2146823133',   # COM error: cannot open
        ]

        is_corrupt = any(sig in err for sig in corrupt_signals)

        if is_corrupt:
            return False, f"Corrupt: {str(e)[:120]}"
        else:
            # Not a corruption error — Word opened fine
            # but something else went wrong (e.g. permissions)
            return None, f"Warning (not corruption): {str(e)[:120]}"

    finally:
        try:
            if doc:
                doc.Close(SaveChanges=False)
        except Exception:
            pass
        try:
            if word:
                word.Quit()
        except Exception:
            pass
        pythoncom.CoUninitialize()


# ─────────────────────────────────────────────────────────────
# BATCH SCANNER
# ─────────────────────────────────────────────────────────────

def validate_docx_opens(file_or_folder, log_file=None):
    """
    Scans single file or entire folder.
    Only flags files Word genuinely cannot open.

    Returns:
        ok_files      : list of (filepath, reason)
        corrupt_files : list of (filepath, reason)
        warn_files    : list of (filepath, reason)  ← opened but had warnings
    """

    # ── Collect files ─────────────────────────────────────────
    if os.path.isdir(file_or_folder):
        files = sorted([
            os.path.join(file_or_folder, f)
            for f in os.listdir(file_or_folder)
            if f.lower().endswith('.docx')
        ])
    else:
        files = [file_or_folder]

    if not files:
        print("No .docx files found.")
        return [], [], []

    ok_files, corrupt_files, warn_files = [], [], []

    print(f"\n{'='*60}")
    print(f"  Validating {len(files)} file(s) via Word")
    print(f"{'='*60}\n")

    for filepath in files:
        name = os.path.basename(filepath)
        print(f"  {name[:55]:<55} ", end='', flush=True)

        success, reason = try_open_in_word(filepath)

        if success is True:
            ok_files.append((filepath, reason))
            print(f"✅ OK")

        elif success is False:
            corrupt_files.append((filepath, reason))
            print(f"❌ CORRUPT")
            print(f"     └─ {reason}")

        else:
            # success is None — warning, not corruption
            warn_files.append((filepath, reason))
            print(f"⚠️  WARN")
            print(f"     └─ {reason}")

    # ── Summary ───────────────────────────────────────────────
    print(f"\n{'='*60}")
    print(f"  Total    : {len(files)}")
    print(f"  ✅ OK     : {len(ok_files)}")
    print(f"  ❌ Corrupt: {len(corrupt_files)}")
    print(f"  ⚠️  Warn  : {len(warn_files)}")
    print(f"{'='*60}")

    if corrupt_files:
        print(f"\n  🚩 CORRUPT FILES:")
        for path, reason in corrupt_files:
            print(f"     • {os.path.basename(path)}")
            print(f"       {reason}")

    if warn_files:
        print(f"\n  ⚠️  WARNING FILES (opened but check manually):")
        for path, reason in warn_files:
            print(f"     • {os.path.basename(path)}")
            print(f"       {reason}")

    # ── Write log ─────────────────────────────────────────────
    if log_file:
        with open(log_file, 'w', encoding='utf-8') as f:
            f.write(f"DOCX Validation — {datetime.now()}\n")
            f.write(f"{'='*60}\n\n")

            f.write(f"✅ OK ({len(ok_files)}):\n")
            for path, reason in ok_files:
                f.write(f"  {os.path.basename(path)} — {reason}\n")

            f.write(f"\n❌ CORRUPT ({len(corrupt_files)}):\n")
            for path, reason in corrupt_files:
                f.write(f"  {os.path.basename(path)}\n")
                f.write(f"    {reason}\n")

            f.write(f"\n⚠️  WARN ({len(warn_files)}):\n")
            for path, reason in warn_files:
                f.write(f"  {os.path.basename(path)}\n")
                f.write(f"    {reason}\n")

        print(f"\n  📄 Log: {log_file}")

    return ok_files, corrupt_files, warn_files


# ─────────────────────────────────────────────────────────────
# PIPELINE INTEGRATION — call after save()
# ─────────────────────────────────────────────────────────────

def save_and_validate(val_report, filepath='', log_file=None):
    """
    Saves + immediately checks if Word can open it.
    Only raises flag for genuine corruption.

    Returns:
        (True,  saved_path)  → clean
        (False, saved_path)  → corrupt — do not distribute
    """
    saved_path = val_report.save(filepath)
    print(f"\n  Saved : {saved_path}")
    print(f"  Checking Word can open it ... ", end='', flush=True)

    success, reason = try_open_in_word(saved_path)

    if success is True:
        print(f"✅ PASS")
        return True, saved_path

    elif success is False:
        print(f"❌ CORRUPT — {reason}")
        if log_file:
            with open(log_file, 'a', encoding='utf-8') as f:
                f.write(
                    f"{datetime.now()} | CORRUPT | "
                    f"{os.path.basename(saved_path)} | {reason}\n"
                )
        return False, saved_path

    else:
        # None = warning only, not corruption
        print(f"⚠️  WARN (opened but check) — {reason}")
        return True, saved_path   # treat warnings as passing


# ─────────────────────────────────────────────────────────────
# USAGE
# ─────────────────────────────────────────────────────────────

# Single file:
# success, reason = try_open_in_word(r"C:\output\file.docx")
# print(success, reason)

# Whole folder:
# ok, corrupt, warn = validate_docx_opens(
#     r"C:\output\folder",
#     log_file=r"C:\output\log.txt"
# )

# In your pipeline after save():
# success, path = save_and_validate(my_val_report, r"C:\out\result.docx")
# if not success:
#     raise RuntimeError(f"Corrupt output: {path}")
```

The three fixes vs the previous version are: `Repair=False` removed — that was causing Word to throw an exception even on valid files because it prevents Word's normal open flow. `doc.Repaired` flag used instead — this is Word's own built-in property that is only `True` when genuine corruption was found and repaired. `success=None` third state added — so permission errors, network issues, or Word crashes don't get misclassified as corruption, they go into a separate warnings bucket instead.
