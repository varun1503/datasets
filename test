@app.post(
    "/validation_report_vr",
    response_model=TriggerResponse,
    status_code=202,
    tags=["validation"],
)
async def validation_report_vr(
    request: Request,
    payload: ValidationReportInput,
    config: dict = Depends(get_config),
):
    if _busy_event.is_set():
        raise HTTPException(status_code=429, detail="Pod is busy – retry later")

    logger.info(f"validation_report_vr payload received: stage_id={payload.stage_id}")

    results = [item.dict() for item in payload.imvp_details]
    df = pd.DataFrame(results)

    submit_vr_task(request, config, payload, df)
    return TriggerResponse(message="Validation report generation triggered successfully")


