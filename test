def safe_copy(elem):
    """
    Deep-copies an lxml element WITHOUT losing namespace declarations.
    Drop-in replacement for etree.fromstring(etree.tostring(elem)).
    """
    import copy
    return copy.deepcopy(elem)


# ══ FIX B: write XML with full namespace declarations
# ══ Replace all your etree.ElementTree(...).write(...) calls with:

def safe_write(tree_or_root, path):
    """
    Writes XML ensuring namespace declarations are not stripped.
    """
    if isinstance(tree_or_root, etree._Element):
        tree = etree.ElementTree(tree_or_root)
    else:
        tree = tree_or_root

    tree.write(
        path,
        xml_declaration=True,       # ← ensures <?xml version="1.0"?>
        encoding='UTF-8',           # ← Word requires explicit encoding
        standalone=True,            # ← matches what Word expects
        pretty_print=True,
    )


