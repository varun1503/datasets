#!/usr/bin/env python3
"""
Repairs a DOCX file with these 5 issues:
  1. No xml declaration: word/charts/copy15_colors1.xml
  2. No xml declaration: word/charts/copy15_style1.xml
  3. Missing style: ListTable4-Accent55
  4. Missing style: Custom1
  5. Missing style: GridTable2-Accent1
"""

import zipfile
import shutil
import os
import sys
import re
from lxml import etree

def repair_docx(input_path: str, output_path: str):
    # ── 1. Extract the zip ────────────────────────────────────────────────────
    tmp_dir = "/tmp/docx_repair"
    if os.path.exists(tmp_dir):
        shutil.rmtree(tmp_dir)
    os.makedirs(tmp_dir)

    with zipfile.ZipFile(input_path, "r") as z:
        z.extractall(tmp_dir)

    # ── 2. Fix missing XML declarations in chart files ────────────────────────
    chart_files = [
        "word/charts/copy15_colors1.xml",
        "word/charts/copy15_style1.xml",
    ]
    XML_DECL = '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>\n'

    for rel_path in chart_files:
        full_path = os.path.join(tmp_dir, rel_path)
        if not os.path.exists(full_path):
            print(f"  [SKIP] {rel_path} not found in archive")
            continue

        with open(full_path, "r", encoding="utf-8") as f:
            content = f.read()

        if content.startswith("<?xml"):
            print(f"  [OK]   {rel_path} already has XML declaration")
        else:
            with open(full_path, "w", encoding="utf-8") as f:
                f.write(XML_DECL + content)
            print(f"  [FIXED] Added XML declaration to {rel_path}")

    # ── 3. Add missing styles to word/styles.xml ─────────────────────────────
    styles_path = os.path.join(tmp_dir, "word/styles.xml")
    if not os.path.exists(styles_path):
        print("ERROR: word/styles.xml not found – is this a valid DOCX?")
        sys.exit(1)

    tree = etree.parse(styles_path)
    root = tree.getroot()

    # Namespace map
    W  = "http://schemas.openxmlformats.org/wordprocessingml/2006/main"
    ns = {"w": W}

    def style_exists(style_id: str) -> bool:
        return root.find(f'.//w:style[@w:styleId="{style_id}"]', ns) is not None

    def append_style_xml(xml_str: str):
        """Parse a <w:style> fragment and append it to <w:styles>."""
        elem = etree.fromstring(xml_str)
        root.append(elem)

    # ── Style definitions ─────────────────────────────────────────────────────
    # ListTable4-Accent55  (table list style, accent colour 5 variant 5)
    LIST_TABLE4_ACCENT55 = f"""<w:style xmlns:w="{W}"
        w:type="table" w:styleId="ListTable4-Accent55">
  <w:name w:val="List Table 4 Accent 5"/>
  <w:basedOn w:val="TableNormal"/>
  <w:uiPriority w:val="52"/>
  <w:rsid w:val="00000000"/>
  <w:tblPr>
    <w:tblStyleRowBandSize w:val="1"/>
    <w:tblStyleColBandSize w:val="1"/>
  </w:tblPr>
  <w:tblStylePr w:type="firstRow">
    <w:rPr>
      <w:b/>
      <w:color w:val="4472C4" w:themeColor="accent1"/>
    </w:rPr>
  </w:tblStylePr>
</w:style>"""

    # Custom1  (generic paragraph style)
    CUSTOM1 = f"""<w:style xmlns:w="{W}"
        w:type="paragraph" w:customStyle="1" w:styleId="Custom1">
  <w:name w:val="Custom1"/>
  <w:basedOn w:val="Normal"/>
  <w:uiPriority w:val="99"/>
  <w:rsid w:val="00000000"/>
  <w:rPr>
    <w:rFonts w:ascii="Calibri" w:hAnsi="Calibri"/>
    <w:sz w:val="24"/>
  </w:rPr>
</w:style>"""

    # GridTable2-Accent1  (grid table style, accent 1 variant 2)
    GRID_TABLE2_ACCENT1 = f"""<w:style xmlns:w="{W}"
        w:type="table" w:styleId="GridTable2-Accent1">
  <w:name w:val="Grid Table 2 Accent 1"/>
  <w:basedOn w:val="TableNormal"/>
  <w:uiPriority w:val="47"/>
  <w:rsid w:val="00000000"/>
  <w:tblPr>
    <w:tblStyleRowBandSize w:val="1"/>
    <w:tblStyleColBandSize w:val="1"/>
  </w:tblPr>
  <w:tblStylePr w:type="firstRow">
    <w:rPr>
      <w:b/>
      <w:color w:val="4472C4" w:themeColor="accent1"/>
    </w:rPr>
  </w:tblStylePr>
</w:style>"""

    styles_to_add = [
        ("ListTable4-Accent55", LIST_TABLE4_ACCENT55),
        ("Custom1",             CUSTOM1),
        ("GridTable2-Accent1",  GRID_TABLE2_ACCENT1),
    ]

    for style_id, xml_str in styles_to_add:
        if style_exists(style_id):
            print(f"  [OK]   Style '{style_id}' already present")
        else:
            append_style_xml(xml_str)
            print(f"  [FIXED] Added missing style '{style_id}'")

    # Write styles.xml back
    tree.write(styles_path, xml_declaration=True, encoding="UTF-8", standalone=True)

    # ── 4. Repack into a new DOCX ─────────────────────────────────────────────
    with zipfile.ZipFile(output_path, "w", zipfile.ZIP_DEFLATED) as zout:
        for dirpath, _, filenames in os.walk(tmp_dir):
            for fname in filenames:
                full = os.path.join(dirpath, fname)
                arcname = os.path.relpath(full, tmp_dir)
                zout.write(full, arcname)

    shutil.rmtree(tmp_dir)
    print(f"\n✅  Repaired DOCX saved to: {output_path}")


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: python repair_docx.py <input.docx> <output.docx>")
        sys.exit(1)
    repair_docx(sys.argv[1], sys.argv[2])
