etree.ElementTree(numdoc).write(path, pretty_print=True)
etree.ElementTree(idxdoc).write(path, pretty_print=True)
etree.ElementTree(stdoc).write(path, pretty_print=True)
etree.ElementTree(reldoc).write(path, pretty_print=True)
etree.ElementTree(self._doc).write(path, pretty_print=True)

# AFTER — replace all of them with safe_write:
