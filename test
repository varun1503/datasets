def copy_content(self, start=''):
    section_title = self.move_cursor(start)

    if self._cursor is None:
        return '', {'data': [], 'styles': [], 'nums': [],
                    'rels': [], 'index': {}}

    original_cursor = self._cursor
    content = {
        'data': [], 'styles': [], 'nums': [],
        'rels': [], 'index': {}
    }
    exclusions = [
        'bookmarkStart', 'bookmarkEnd', 'footnoteReference',
        'endnoteReference', 'commentRangeStart',
        'commentRangeEnd', 'commentReference'
    ]
    start_olvl = self.get_outline_level(self._cursor)

    # ── Track seen element signatures to prevent duplicates ──
    seen_signatures = set()

    def get_signature(elem):
        """Unique signature for an element to detect duplicates."""
        texts = ''.join(
            t.text or ''
            for t in elem.iter(
                '{http://schemas.openxmlformats.org/wordprocessingml/2006/main}t'
            )
        )
        return f"{etree.QName(elem).localname}::{texts[:100]}"

    while True:
        nxt = self._cursor.getnext()
        if nxt is None:
            break

        nxt_text = get_text(nxt, self._doc.nsmap).strip()
        nxt_olvl = self.get_outline_level(nxt)

        if (nxt_olvl != -1 and nxt_text != ''
                and start_olvl != -1 and nxt_olvl <= start_olvl):
            break

        xx = copy.deepcopy(nxt)   # ✅ safe copy

        for x in xx.xpath(
            ' | '.join(['.//w:' + e for e in exclusions]),
            namespaces=self._doc.nsmap
        ):
            x.getparent().remove(x)

        # ✅ use fixed clean_paragraph
        if etree.QName(xx).localname == 'p':
            clean_paragraph(xx, self._doc.nsmap)

        elif etree.QName(xx).localname == 'tbl':
            for x in xx.xpath('.//w:tblStyle', namespaces=self._doc.nsmap):
                k = f'{{{self._doc.nsmap["w"]}}}val'
                content['styles'].append((x.get(k), k, x))

        # ✅ deduplication check
        sig = get_signature(xx)
        if sig not in seen_signatures:
            seen_signatures.add(sig)
            content['rels'] += [
                (v, k, x)
                for x in xx.findall('.//*')
                for k, v in x.attrib.items()
                if v.startswith('rId')
            ]
            content['nums'] += [
                (v, k, x)
                for x in xx.findall('.//w:numPr/w:numId', self._doc.nsmap)
                for k, v in x.attrib.items()
                if k.endswith('val')
            ]
            content['data'].append(xx)

        self._cursor = nxt

    if content['data']:
        self.get_relationships(content)
        self.get_numbering(content)
        self.get_styles(content)
        return section_title, content

    # ── Second pass fallback (section number based) ───────────
    self._cursor = original_cursor
    content = {
        'data': [], 'styles': [], 'nums': [],
        'rels': [], 'index': {}
    }
    seen_signatures = set()   # ✅ reset for second pass
    start_section = extract_section_number(start)

    def is_child_section(child, parent):
        if not child or not parent:
            return False
        return child == parent or child.startswith(parent + '.')

    started = False

    while True:
        nxt = self._cursor.getnext()
        if nxt is None:
            break

        nxt_text    = get_text(nxt, self._doc.nsmap).strip()
        nxt_section = extract_section_number(nxt_text)

        if not started:
            if nxt_section and is_child_section(nxt_section, start_section):
                started = True
            else:
                self._cursor = nxt
                continue

        if nxt_section and not is_child_section(nxt_section, start_section):
            break

        xx = copy.deepcopy(nxt)   # ✅ safe copy

        for x in xx.xpath(
            ' | '.join(['.//w:' + e for e in exclusions]),
            namespaces=self._doc.nsmap
        ):
            x.getparent().remove(x)

        # ✅ use fixed clean_paragraph
        if etree.QName(xx).localname == 'p':
            clean_paragraph(xx, self._doc.nsmap)

        elif etree.QName(xx).localname == 'tbl':
            for x in xx.xpath('.//w:tblStyle', namespaces=self._doc.nsmap):
                k = f'{{{self._doc.nsmap["w"]}}}val'
                content['styles'].append((x.get(k), k, x))

        # ✅ deduplication check
        sig = get_signature(xx)
        if sig not in seen_signatures:
            seen_signatures.add(sig)
            content['rels'] += [
                (v, k, x)
                for x in xx.findall('.//*')
                for k, v in x.attrib.items()
                if v.startswith('rId')
            ]
            content['nums'] += [
                (v, k, x)
                for x in xx.findall('.//w:numPr/w:numId', self._doc.nsmap)
                for k, v in x.attrib.items()
                if k.endswith('val')
            ]
            content['data'].append(xx)

        self._cursor = nxt

    self.get_relationships(content)
    self.get_numbering(content)
    self.get_styles(content)

    return section_title, content
