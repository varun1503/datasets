"""
Optimized move_cursor implementation with robust section matching.

Key improvements:
  1. Hard section-number gate  — section numbers must match exactly when both present
  2. Multi-signal scoring      — combines token_set_ratio + partial_ratio + exact bonus
  3. Configurable thresholds   — MIN_THRESHOLD and SECTION_BOOST are tunable params
  4. Ambiguity guard           — rejects match when top-2 scores are too close (prevents
                                 "Assumptions and Limitations" style false picks)
  5. Early-exit optimisation   — perfect score short-circuits the loop
  6. Logging / debug support   — pass debug=True to trace scoring decisions
  7. No retrieval contract     — returns '' (not None) so callers never need null-checks
"""

import logging
from dataclasses import dataclass, field
from typing import Optional

from rapidfuzz import fuzz  # drop-in for fuzzywuzzy, 10-40x faster

logger = logging.getLogger(__name__)


# ---------------------------------------------------------------------------
# Tunable configuration  (can be loaded from a config file / env vars so that
# the MRMG team can adjust thresholds without touching code)
# ---------------------------------------------------------------------------
@dataclass
class MatchConfig:
    # Minimum combined score to accept a match
    min_threshold: float = 75.0

    # How much extra weight to give when section numbers match exactly
    section_boost: float = 15.0

    # If the top-2 candidates are within this band, treat as ambiguous → no retrieval
    ambiguity_margin: float = 5.0

    # Weights for the three fuzz signals
    weight_ratio: float = 0.4
    weight_token_set: float = 0.4
    weight_partial: float = 0.2

    # Outline levels to skip (non-heading paragraphs in python-docx/lxml world)
    skip_levels: tuple = (-1, 9)


_DEFAULT_CONFIG = MatchConfig()


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------
def _combined_score(a: str, b: str, cfg: MatchConfig) -> float:
    """
    Weighted blend of three fuzz metrics for more stable title matching.

    - fuzz.ratio           : character-level similarity (good for short titles)
    - fuzz.token_set_ratio : order-insensitive, handles reworded titles well
    - fuzz.partial_ratio   : catches one title being a substring of the other
    """
    r  = fuzz.ratio(a, b)
    ts = fuzz.token_set_ratio(a, b)
    pr = fuzz.partial_ratio(a, b)
    return (
        cfg.weight_ratio    * r  +
        cfg.weight_token_set * ts +
        cfg.weight_partial  * pr
    )


@dataclass
class _Candidate:
    node: object
    raw_text: str
    score: float


# ---------------------------------------------------------------------------
# Main method  (drop this into your class, replacing the old move_cursor)
# ---------------------------------------------------------------------------
def move_cursor(
    self,
    to: str = '',
    *,
    cfg: MatchConfig = _DEFAULT_CONFIG,
    debug: bool = False,
) -> str:
    """
    Move the internal cursor to the paragraph in the Word document that best
    matches *to* (a section heading string, optionally prefixed by a section
    number such as "3.2 Business problem solved by the model").

    Returns the matched paragraph's text, or '' if no confident match found.
    """
    self._cursor = None

    if not to or not to.strip():
        return ''

    input_section: str = extract_section_number(to)          # e.g. "3.2"
    input_title: str   = remove_section_number(to).lower().strip()

    if debug:
        logger.debug("move_cursor seeking: section=%r  title=%r", input_section, input_title)

    candidates: list[_Candidate] = []

    for xx in self._doc.xpath('.//w:body/w:p', namespaces=self._doc.nsmap):
        raw_text = get_text(xx, self._doc.nsmap)
        if not raw_text or not raw_text.strip():
            continue

        olvl = self.get_outline_level(xx)
        if olvl in cfg.skip_levels:
            continue

        doc_section: str = extract_section_number(raw_text)
        doc_title: str   = remove_section_number(raw_text).lower().strip()

        if not doc_title:
            continue

        # ------------------------------------------------------------------
        # Gate 1 — hard section-number filter
        #   • Both sides have a number  → must match exactly, otherwise skip.
        #   • Input has a number, doc doesn't → skip (avoids matching bare
        #     headings like "Assumptions and Limitations" without a number).
        # ------------------------------------------------------------------
        if input_section:
            if not doc_section:
                continue                          # doc paragraph has no number
            if doc_section != input_section:
                continue                          # numbers present but differ

        # ------------------------------------------------------------------
        # Gate 2 — title must be non-trivially populated
        # ------------------------------------------------------------------
        if len(doc_title) < 3:
            continue

        # ------------------------------------------------------------------
        # Scoring — weighted multi-signal fuzzy match
        # ------------------------------------------------------------------
        score = _combined_score(input_title, doc_title, cfg)

        # Small bonus when section numbers agree (already gated above, but
        # this rewards exact-number matches vs. cases where input has no
        # section number and we fall through)
        if input_section and doc_section == input_section:
            score += cfg.section_boost

        # Cap at 100 for cleanliness
        score = min(score, 100.0)

        if debug:
            logger.debug(
                "  candidate  score=%.1f  section=%r  title=%r",
                score, doc_section, doc_title,
            )

        candidates.append(_Candidate(node=xx, raw_text=raw_text, score=score))

        # Early exit on perfect match
        if score >= 100.0:
            break

    if not candidates:
        if debug:
            logger.debug("  → no candidates found, returning ''")
        return ''

    # Sort descending by score
    candidates.sort(key=lambda c: c.score, reverse=True)
    best = candidates[0]

    # ------------------------------------------------------------------
    # Ambiguity guard — if 2nd-best is within `ambiguity_margin` of best,
    # we cannot be confident; return no-retrieval rather than guess wrong.
    # This specifically handles generic titles like "Assumptions and
    # Limitations" appearing in multiple sections.
    # ------------------------------------------------------------------
    if len(candidates) > 1:
        second_best = candidates[1]
        if (best.score - second_best.score) < cfg.ambiguity_margin:
            if debug:
                logger.debug(
                    "  → ambiguous match (best=%.1f  2nd=%.1f  margin=%.1f), returning ''",
                    best.score, second_best.score, cfg.ambiguity_margin,
                )
            return ''

    # ------------------------------------------------------------------
    # Final threshold check
    # ------------------------------------------------------------------
    if best.score < cfg.min_threshold:
        if debug:
            logger.debug(
                "  → best score %.1f below threshold %.1f, returning ''",
                best.score, cfg.min_threshold,
            )
        return ''

    if debug:
        logger.debug(
            "  → matched  score=%.1f  text=%r",
            best.score, best.raw_text,
        )

    self._cursor = best.node
    return get_text(best.node, self._doc.nsmap)


# ---------------------------------------------------------------------------
# Example: how to make thresholds MRMG-configurable without code changes
# ---------------------------------------------------------------------------
# In your config.yaml / .env:
#
#   MATCH_MIN_THRESHOLD=75
#   MATCH_SECTION_BOOST=15
#   MATCH_AMBIGUITY_MARGIN=5
#
# Then at startup:
#
#   import os
#   MATCH_CONFIG = MatchConfig(
#       min_threshold     = float(os.getenv("MATCH_MIN_THRESHOLD",     75)),
#       section_boost     = float(os.getenv("MATCH_SECTION_BOOST",     15)),
#       ambiguity_margin  = float(os.getenv("MATCH_AMBIGUITY_MARGIN",   5)),
#   )
#
# And pass it in every call:
#   self.move_cursor(to=heading, cfg=MATCH_CONFIG)
# ---------------------------------------------------------------------------
