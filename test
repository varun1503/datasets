No, this code **will not work on GCP or AWS** because it uses `win32com` which requires:

- **Windows OS** — GCP/AWS Linux instances don't have it
- **Microsoft Word installed** — servers never have Word
- **COM automation** — Linux has no COM layer

Here are your alternatives depending on your cloud setup:

```python
# ─────────────────────────────────────────────────────────────
# OPTION 1: LibreOffice (Best for GCP/AWS Linux)
# Install: sudo apt-get install libreoffice
# Free, no license needed, works headless
# ─────────────────────────────────────────────────────────────

import subprocess
import os
import tempfile
import shutil
from datetime import datetime


def try_open_libreoffice(filepath, timeout=60):
    """
    Uses LibreOffice headless to convert docx → pdf.
    If conversion fails → file is corrupt.
    If conversion succeeds → file opens cleanly.

    Works on: Linux, GCP, AWS, Docker
    Install  : sudo apt-get install -y libreoffice
    """
    filepath = os.path.abspath(filepath)

    if not os.path.exists(filepath):
        return False, "File not found"

    # ── Use temp output dir so we don't pollute working dir ──
    tmp_dir = tempfile.mkdtemp()

    try:
        result = subprocess.run(
            [
                'libreoffice',
                '--headless',
                '--norestore',        # don't restore previous crashes
                '--nofirststartwizard',
                '--convert-to', 'pdf',
                '--outdir', tmp_dir,
                filepath,
            ],
            stdout  = subprocess.PIPE,
            stderr  = subprocess.PIPE,
            timeout = timeout,
        )

        stdout = result.stdout.decode('utf-8', errors='replace')
        stderr = result.stderr.decode('utf-8', errors='replace')

        # ── Check output PDF was actually created ─────────────
        filename_no_ext = os.path.splitext(os.path.basename(filepath))[0]
        pdf_path = os.path.join(tmp_dir, filename_no_ext + '.pdf')
        pdf_exists = os.path.exists(pdf_path)
        pdf_size   = os.path.getsize(pdf_path) if pdf_exists else 0

        # ── Detect corruption from output ─────────────────────
        corrupt_signals = [
            'error',
            'failed',
            'corrupt',
            'cannot open',
            'password',
            'filter not found',
        ]

        output_lower = (stdout + stderr).lower()
        has_error    = any(s in output_lower for s in corrupt_signals)

        if result.returncode != 0 or has_error or not pdf_exists or pdf_size == 0:
            return False, (
                f"LibreOffice failed "
                f"(returncode={result.returncode}, "
                f"pdf_exists={pdf_exists}, "
                f"pdf_size={pdf_size})\n"
                f"stdout: {stdout[:200]}\n"
                f"stderr: {stderr[:200]}"
            )

        return True, f"OK — PDF created ({pdf_size} bytes)"

    except subprocess.TimeoutExpired:
        return False, f"Timed out after {timeout}s — file may be corrupt or too large"

    except FileNotFoundError:
        return None, "LibreOffice not installed — run: sudo apt-get install -y libreoffice"

    except Exception as e:
        return None, f"Unexpected error: {e}"

    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)


# ─────────────────────────────────────────────────────────────
# OPTION 2: python-docx structural check (No install needed)
# Lighter than LibreOffice — pure Python
# Catches most corruption without needing Word or LibreOffice
# ─────────────────────────────────────────────────────────────

def try_open_python_docx(filepath):
    """
    Uses python-docx to open and parse the document.
    Catches XML errors, missing parts, broken structure.

    Install: pip install python-docx
    Works on: Linux, GCP, AWS, Docker, anywhere
    """
    try:
        from docx import Document
        from docx.opc.exceptions import PackageNotFoundError
    except ImportError:
        return None, "python-docx not installed — run: pip install python-docx"

    filepath = os.path.abspath(filepath)

    if not os.path.exists(filepath):
        return False, "File not found"

    try:
        # ── Open and fully parse ──────────────────────────────
        doc = Document(filepath)

        # ── Force full content read ───────────────────────────
        para_count  = len(doc.paragraphs)
        table_count = len(doc.tables)
        section_count = len(doc.sections)

        # ── Check paragraphs are readable ─────────────────────
        total_text = 0
        for para in doc.paragraphs:
            total_text += len(para.text)

        # ── Check tables are readable ─────────────────────────
        for table in doc.tables:
            for row in table.rows:
                for cell in row.cells:
                    _ = cell.text

        return True, (
            f"OK — {para_count} paragraphs, "
            f"{table_count} tables, "
            f"{total_text} chars"
        )

    except PackageNotFoundError as e:
        return False, f"Corrupt — not a valid docx package: {e}"

    except Exception as e:
        err = str(e).lower()
        corrupt_signals = [
            'corrupt', 'invalid', 'bad zip',
            'xml', 'unexpected', 'missing',
            'none', 'attribute', 'parse'
        ]
        if any(s in err for s in corrupt_signals):
            return False, f"Corrupt — {e}"
        else:
            return None, f"Warning (not corruption): {e}"


# ─────────────────────────────────────────────────────────────
# COMBINED VALIDATOR
# Uses both checks together for maximum accuracy on cloud
# ─────────────────────────────────────────────────────────────

def try_open_in_cloud(filepath, method='auto'):
    """
    Auto-selects best available method for cloud environments.

    method:
        'auto'        → tries LibreOffice first, falls back to python-docx
        'libreoffice' → LibreOffice only
        'python-docx' → python-docx only
        'both'        → runs both, flags if either fails

    Returns:
        (True,  reason)  → clean
        (False, reason)  → corrupt
        (None,  reason)  → could not validate (missing tools)
    """
    filepath = os.path.abspath(filepath)

    if method == 'libreoffice':
        return try_open_libreoffice(filepath)

    if method == 'python-docx':
        return try_open_python_docx(filepath)

    if method == 'both':
        lo_ok,  lo_reason  = try_open_libreoffice(filepath)
        pdx_ok, pdx_reason = try_open_python_docx(filepath)

        if lo_ok is False:
            return False, f"LibreOffice: {lo_reason}"
        if pdx_ok is False:
            return False, f"python-docx: {pdx_reason}"
        if lo_ok is True and pdx_ok is True:
            return True, f"Both checks passed"

        return None, f"LO={lo_reason} | PDX={pdx_reason}"

    # ── auto: try LibreOffice first ───────────────────────────
    if shutil.which('libreoffice'):
        ok, reason = try_open_libreoffice(filepath)
        if ok is not None:
            return ok, f"[LibreOffice] {reason}"

    # ── fallback to python-docx ───────────────────────────────
    return try_open_python_docx(filepath)


# ─────────────────────────────────────────────────────────────
# BATCH SCANNER FOR CLOUD
# ─────────────────────────────────────────────────────────────

def validate_docx_opens_cloud(
    file_or_folder,
    method   = 'auto',
    log_file = None,
):
    """
    Cloud-compatible batch validator.
    Drop-in replacement for validate_docx_opens().
    """
    if os.path.isdir(file_or_folder):
        files = sorted([
            os.path.join(file_or_folder, f)
            for f in os.listdir(file_or_folder)
            if f.lower().endswith('.docx')
        ])
    else:
        files = [file_or_folder]

    if not files:
        print("No .docx files found.")
        return [], [], []

    ok_files, corrupt_files, warn_files = [], [], []

    print(f"\n{'='*60}")
    print(f"  Cloud DOCX Validator  (method={method})")
    print(f"  Validating {len(files)} file(s)")
    print(f"{'='*60}\n")

    for filepath in files:
        name = os.path.basename(filepath)
        print(f"  {name[:50]:<50} ", end='', flush=True)

        success, reason = try_open_in_cloud(filepath, method=method)

        if success is True:
            ok_files.append((filepath, reason))
            print("✅ OK")

        elif success is False:
            corrupt_files.append((filepath, reason))
            print("❌ CORRUPT")
            print(f"     └─ {reason}")

        else:
            warn_files.append((filepath, reason))
            print("⚠️  WARN")
            print(f"     └─ {reason}")

    # ── Summary ───────────────────────────────────────────────
    print(f"\n{'='*60}")
    print(f"  ✅ OK     : {len(ok_files)}")
    print(f"  ❌ Corrupt: {len(corrupt_files)}")
    print(f"  ⚠️  Warn  : {len(warn_files)}")
    print(f"{'='*60}")

    if corrupt_files:
        print(f"\n  🚩 CORRUPT FILES:")
        for path, reason in corrupt_files:
            print(f"     • {os.path.basename(path)}")
            print(f"       {reason}")

    # ── Log ───────────────────────────────────────────────────
    if log_file:
        with open(log_file, 'w', encoding='utf-8') as f:
            f.write(f"Cloud DOCX Validation — {datetime.now()}\n")
            f.write(f"Method: {method}\n{'='*60}\n\n")
            f.write(f"OK ({len(ok_files)}):\n")
            for p, r in ok_files:
                f.write(f"  {os.path.basename(p)} — {r}\n")
            f.write(f"\nCORRUPT ({len(corrupt_files)}):\n")
            for p, r in corrupt_files:
                f.write(f"  {os.path.basename(p)}\n    {r}\n")
            f.write(f"\nWARN ({len(warn_files)}):\n")
            for p, r in warn_files:
                f.write(f"  {os.path.basename(p)}\n    {r}\n")
        print(f"\n  📄 Log: {log_file}")

    return ok_files, corrupt_files, warn_files


# ─────────────────────────────────────────────────────────────
# PIPELINE INTEGRATION
# ─────────────────────────────────────────────────────────────

def save_and_validate_cloud(val_report, filepath='', log_file=None):
    """
    Save + validate in one call. Works on GCP/AWS/Docker.
    """
    saved_path = val_report.save(filepath)
    print(f"\n  Saved : {saved_path}")
    print(f"  Validating ... ", end='', flush=True)

    success, reason = try_open_in_cloud(saved_path)

    if success is True:
        print(f"✅ PASS — {reason}")
        return True, saved_path
    elif success is False:
        print(f"❌ CORRUPT — {reason}")
        if log_file:
            with open(log_file, 'a', encoding='utf-8') as f:
                f.write(f"{datetime.now()} | CORRUPT | {saved_path} | {reason}\n")
        return False, saved_path
    else:
        print(f"⚠️  WARN — {reason}")
        return True, saved_path


