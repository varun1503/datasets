                jc.set(f'{{{W}}}val', align)
                r = etree.SubElement(p, f'{{{W}}}r')
                t = etree.SubElement(r, f'{{{W}}}t')
                t.text = text
                if page_field:
                    # Add "Page " run + PAGE field
                    r2 = etree.SubElement(p, f'{{{W}}}r')
                    t2 = etree.SubElement(r2, f'{{{W}}}t')
                    t2.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
                    t2.text = 'Page '
                    # fldChar begin
                    r3 = etree.SubElement(p, f'{{{W}}}r')
                    fc1 = etree.SubElement(r3, f'{{{W}}}fldChar')
                    fc1.set(f'{{{W}}}fldCharType', 'begin')
                    # instrText
                    r4 = etree.SubElement(p, f'{{{W}}}r')
                    instr = etree.SubElement(r4, f'{{{W}}}instrText')
                    instr.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
                    instr.text = ' PAGE '
                    # fldChar end
                    r5 = etree.SubElement(p, f'{{{W}}}r')
                    fc2 = etree.SubElement(r5, f'{{{W}}}fldChar')
                    fc2.set(f'{{{W}}}fldCharType', 'end')
                    # Remove the empty first run
                    p.remove(r)

            make_cell(date, 'left')
            make_cell('AXP Internal', 'center')
            make_cell('', 'right', page_field=True)

            footer_bytes = etree.tostring(ftr, xml_declaration=True,
                                          encoding='UTF-8', standalone=True)

            sectPr = section._sectPr
            self._remove_refs(sectPr, 'w:footerReference')
            rId = self._make_part(footer_bytes, 'footer', 'footer', 'footer', i + 1)
            ftrRef = OxmlElement('w:footerReference')
            ftrRef.set(qn('w:type'), 'default')
            ftrRef.set(qn('r:id'), rId)
            sectPr.append(ftrRef)

    def process(self, model_id, model_name, date=None):
        self.update_header(model_id, model_name)
        self.create_or_update_footer(date)
        self.doc.save(self.output_path)
