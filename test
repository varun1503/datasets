#     print(f"✅ OK")


# ── In your pipeline after save() ────────────────────────────

def save_and_validate(val_report, filepath=''):
    saved_path = val_report.save(filepath)

    ok, reason = will_word_open(saved_path)

    if ok:
        print(f"✅ PASS — {saved_path}")
    else:
        print(f"❌ CORRUPT — {reason}")

    return ok, saved_path
```

Usage is just two lines anywhere in your code:

```python
ok, reason = will_word_open(r"C:\output\myfile.docx")
if not ok:
    print(f"FLAGGED: {reason}")
```
