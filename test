# ---------------------------------------------------------------------------
# Background task helpers
# ---------------------------------------------------------------------------
def _run_vr_task(request: Request, config: dict, payload: ValidationReportInput, df) -> None:
    """
    Runs inside the thread-pool worker.
    Sets the busy flag, executes the heavy task, then clears the flag.
    """
    _busy_event.set()
    try:
        mrmg_execute_vr(request, config, payload, df)
    except Exception as e:
        logger.exception(f"Background VR task failed: {e}")
    finally:
        _busy_event.clear()


def submit_vr_task(request: Request, config: dict, payload: ValidationReportInput, df) -> None:
    """Submit the VR task to the single-worker executor."""
    executor.submit(_run_vr_task, request, config, payload, df)


