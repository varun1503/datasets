```python
# Cell 6 - (Optional) Batch Convert Multiple Files
import glob

DOCX_FOLDER  = "./docs"    # Folder containing .docx files
OUTPUT_FOLDER = "./output" # Folder to save all PDFs

docx_files = glob.glob(os.path.join(DOCX_FOLDER, "*.docx"))

if not docx_files:
    print("⚠️  No .docx files found in", DOCX_FOLDER)
else:
    print(f"🔄 Found {len(docx_files)} file(s). Converting...\n")
    for docx in docx_files:
        try:
            pdf = convert_docx_to_pdf(docx, OUTPUT_FOLDER)
            print(f"  ✅ {os.path.basename(docx)} → {os.path.basename(pdf)}")
        except Exception as e:
            print(f"  ❌ {os.path.basename(docx)} failed: {e}")

    print("\n✅ Batch conversion complete!")
```

