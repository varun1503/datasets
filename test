class DocumentUpdater:

    def __init__(self, input_path, output_path):
        self.input_path = input_path
        self.output_path = output_path
        self.doc = Document(input_path)

    def _make_part(self, xml_bytes, part_type, rel_type, name_prefix, index):
        CT_MAP = {
            'header': 'application/vnd.openxmlformats-officedocument.wordprocessingml.header+xml',
            'footer': 'application/vnd.openxmlformats-officedocument.wordprocessingml.footer+xml',
        }
        REL_MAP = {
            'header': 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/header',
            'footer': 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/footer',
        }
        part_uri = PackURI(f'/word/{name_prefix}_custom_{index}.xml')
        part = Part(part_uri, CT_MAP[part_type], xml_bytes, self.doc.part.package)
        rId = self.doc.part.relate_to(part, REL_MAP[part_type])
        return rId

    def _remove_refs(self, sectPr, ref_tag):
        for ref in sectPr.findall(qn(ref_tag)):
            rId_old = ref.get(qn('r:id'))
            try:
                self.doc.part.drop_rel(rId_old)
            except:
                pass
            sectPr.remove(ref)

    def update_header(self, model_id, model_name):
        new_text = f"{model_id} {model_name} - Validation Report"
        W = 'http://schemas.openxmlformats.org/wordprocessingml/2006/main'
        R = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'

        hdr = etree.Element(f'{{{W}}}hdr', nsmap={'w': W, 'r': R})
        p = etree.SubElement(hdr, f'{{{W}}}p')
        pPr = etree.SubElement(p, f'{{{W}}}pPr')
        jc = etree.SubElement(pPr, f'{{{W}}}jc')
        jc.set(f'{{{W}}}val', 'center')
        pBdr = etree.SubElement(pPr, f'{{{W}}}pBdr')
        bottom = etree.SubElement(pBdr, f'{{{W}}}bottom')
        bottom.set(f'{{{W}}}val', 'single')
        bottom.set(f'{{{W}}}sz', '12')
        bottom.set(f'{{{W}}}space', '1')
        bottom.set(f'{{{W}}}color', '000000')
        r = etree.SubElement(p, f'{{{W}}}r')
        t = etree.SubElement(r, f'{{{W}}}t')
        t.text = new_text
        header_bytes = etree.tostring(hdr, xml_declaration=True,
                                      encoding='UTF-8', standalone=True)

        for i, section in enumerate(self.doc.sections):
            sectPr = section._sectPr
            self._remove_refs(sectPr, 'w:headerReference')
            rId = self._make_part(header_bytes, 'header', 'header', 'header', i + 1)
            hdrRef = OxmlElement('w:headerReference')
            hdrRef.set(qn('w:type'), 'default')
            hdrRef.set(qn('r:id'), rId)
            sectPr.insert(0, hdrRef)

    def create_or_update_footer(self, date=None):
        if date is None:
