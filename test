import re
from fuzzywuzzy import fuzz


# =========================
# 🔢 Number Tracker (FIXED)
# =========================
class SimpleNumberTracker:
    def __init__(self):
        self.counters = [0] * 10
        self.current_numId = None   # 🔥 track numbering sequence

    def reset(self):
        self.counters = [0] * 10

    def get_number(self, ilvl, numId=None):
        # 🔥 Reset when new numbering sequence starts
        if numId != self.current_numId:
            print("🔄 Reset tracker (new numId)")
            self.reset()
            self.current_numId = numId

        self.counters[ilvl] += 1

        # Reset deeper levels
        for i in range(ilvl + 1, len(self.counters)):
            self.counters[i] = 0

        return ".".join(
            str(c) for c in self.counters[:ilvl + 1] if c > 0
        )


# 🔥 Global tracker
tracker = SimpleNumberTracker()


# =========================
# 🔍 Helper: get numId
# =========================
def get_numId(p, nsmap):
    numId = p.find('.//w:numId', namespaces=nsmap)
    if numId is not None:
        return numId.get(f"{{{nsmap['w']}}}val")
    return None


# =========================
# 📝 Extract Text Function
# =========================
def get_text(p, nsmap):
    texts = []

    for x in p.xpath('.//w:t', namespaces=nsmap):
        if x.text:
            texts.append(x.text)

    full_text = ''.join(texts).strip()

    # ✅ FIX: avoid None crash
    if not full_text:
        return ""

    print("\n----------------------")
    print("TEXT:", full_text)

    numPr = p.find('./w:pPr/w:numPr', namespaces=nsmap)

    if numPr is None:
        print("❌ No numbering found in XML")
    else:
        print("✅ Numbering found")

    # =========================
    # ✅ Case 1: Manual numbering
    # =========================
    if re.match(r'^\d+(\.\d+)*\.?\s+', full_text):
        print("➡️ Manual numbering detected")
        return full_text

    # =========================
    # ✅ Case 2: Auto-numbering (FIXED)
    # =========================
    if numPr is not None:
        ilvl_el = numPr.find('./w:ilvl', namespaces=nsmap)

        if ilvl_el is not None:
            ilvl = int(ilvl_el.get(f"{{{nsmap['w']}}}val"))

            numId = get_numId(p, nsmap)   # 🔥 NEW FIX

            number = tracker.get_number(ilvl, numId)

            print(f"➡️ Auto numbering applied: {number}")

            if number:
                return f"{number} {full_text}"

    # =========================
    # ✅ Case 3: Normal text
    # =========================
    print("➡️ No numbering applied")
    return full_text


