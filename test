#!/usr/bin/env python3
"""
recover_docx.py
---------------
Recovers EVERYTHING from a corrupted .docx into a clean new document.
Preserves: headings, paragraphs, bold/italic/underline, font size & color,
           alignment, bullet/numbered lists, tables (with cell formatting),
           and embedded images.

Usage:
    python3 recover_docx.py corrupt.docx
    python3 recover_docx.py corrupt.docx --out recovered.docx
"""

import argparse
import sys
import traceback
from pathlib import Path
from copy import deepcopy

from docx import Document
from docx.shared import Pt, RGBColor, Inches
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.oxml.ns import qn
from docx.oxml import OxmlElement
import zipfile
import os
import tempfile
import shutil


# ── Helpers ──────────────────────────────────────────────────────────────────

def safe(fn, default=None):
    """Call fn(), return default on any exception."""
    try:
        return fn()
    except Exception:
        return default


def copy_run_format(src_run, dst_run):
    """Copy all character formatting from src_run → dst_run."""
    safe(lambda: setattr(dst_run, "bold",      src_run.bold))
    safe(lambda: setattr(dst_run, "italic",    src_run.italic))
    safe(lambda: setattr(dst_run, "underline", src_run.underline))
    safe(lambda: setattr(dst_run, "strike",    src_run.font.strike))

    size = safe(lambda: src_run.font.size)
    if size:
        dst_run.font.size = size

    color = safe(lambda: src_run.font.color.rgb)
    if color:
        dst_run.font.color.rgb = color

    name = safe(lambda: src_run.font.name)
    if name:
        dst_run.font.name = name


def copy_paragraph_format(src_para, dst_para):
    """Copy paragraph-level formatting."""
    align = safe(lambda: src_para.alignment)
    if align is not None:
        dst_para.alignment = align

    fmt = src_para.paragraph_format
    dst_fmt = dst_para.paragraph_format

    space_before = safe(lambda: fmt.space_before)
    if space_before:
        dst_fmt.space_before = space_before

    space_after = safe(lambda: fmt.space_after)
    if space_after:
        dst_fmt.space_after = space_after


def get_image_rels(doc):
    """Return {rId: image_bytes} for all images in the document."""
    images = {}
    try:
        for rel in doc.part.rels.values():
            if "image" in rel.reltype:
                try:
                    images[rel.rId] = rel.target_part.blob
                except Exception:
                    pass
    except Exception:
        pass
    return images


def add_image_to_para(new_doc, para, image_blob, ext="png"):
    """Save image blob to temp file and add to paragraph."""
    import tempfile, os
    suffix = f".{ext}"
    with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as f:
        f.write(image_blob)
        tmp = f.name
    try:
        run = para.add_run()
        run.add_picture(tmp, width=Inches(5))
    except Exception as e:
        para.add_run(f"[Image could not be embedded: {e}]")
    finally:
        os.unlink(tmp)


def recover_paragraph(src_para, new_doc, image_rels):
    """
    Recover one paragraph (heading, normal, list, or inline image)
    into new_doc. Returns the new paragraph.
    """
    style_name = safe(lambda: src_para.style.name, "Normal")

    # Map corrupted/missing styles to safe defaults
    safe_styles = {
        "Normal", "Heading 1", "Heading 2", "Heading 3",
        "Heading 4", "List Bullet", "List Number",
        "List Paragraph", "Caption", "Quote",
    }
    use_style = style_name if style_name in safe_styles else "Normal"

    new_para = new_doc.add_paragraph(style=use_style)
    copy_paragraph_format(src_para, new_para)

    for run in src_para.runs:
        # Check if this run contains an inline image
        drawing = run._r.find(qn("w:drawing"))
        if drawing is not None:
            # Try to extract image
            blip = drawing.find(".//" + qn("a:blip"))
            if blip is not None:
                rId = blip.get(qn("r:embed"))
                if rId and rId in image_rels:
                    # Guess extension
                    blob = image_rels[rId]
                    ext = "png"
                    if blob[:3] == b"\xff\xd8\xff":
                        ext = "jpg"
                    elif blob[:4] == b"\x89PNG":
                        ext = "png"
                    add_image_to_para(new_doc, new_para, blob, ext)
                    continue
            new_para.add_run("[image]")
            continue

        text = safe(lambda: run.text, "")
        if text is None:
            text = ""
        new_run = new_para.add_run(text)
        copy_run_format(run, new_run)

    return new_para


def recover_table(src_table, new_doc):
    """Copy a table into new_doc preserving cell text and basic formatting."""
    rows = safe(lambda: len(src_table.rows), 0)
    cols = safe(lambda: len(src_table.columns), 0)
    if rows == 0 or cols == 0:
        return

    new_table = new_doc.add_table(rows=rows, cols=cols)
    # Apply a clean built-in style
    try:
        new_table.style = "Table Grid"
    except Exception:
        pass

    for i, src_row in enumerate(src_table.rows):
        for j, src_cell in enumerate(src_row.cells):
            dst_cell = new_table.rows[i].cells[j]
            dst_cell.text = ""  # clear default empty paragraph

            for k, src_para in enumerate(src_cell.paragraphs):
                if k == 0:
                    dst_para = dst_cell.paragraphs[0]
                    dst_para.style = new_doc.styles["Normal"]
                else:
                    dst_para = dst_cell.add_paragraph()

                copy_paragraph_format(src_para, dst_para)
                for run in src_para.runs:
                    text = safe(lambda: run.text, "") or ""
                    new_run = dst_para.add_run(text)
                    copy_run_format(run, new_run)


# ── Main recovery ─────────────────────────────────────────────────────────────

def recover(src_path: Path, dst_path: Path):
    print(f"\n🔧 Opening corrupted document: {src_path}")

    # Try to open — even partially broken files often load with warnings
    try:
        doc = Document(str(src_path))
    except Exception as e:
        print(f"  ⚠️  python-docx warning: {e}")
        print("  Attempting low-level ZIP extraction...")
        # If docx is a valid ZIP but has XML issues, try repairing it first
        try:
            doc = _repair_and_open(src_path)
        except Exception as e2:
            print(f"  ❌ Could not open document: {e2}")
            sys.exit(1)

    print("  ✓ Document opened")

    image_rels = get_image_rels(doc)
    print(f"  ✓ Found {len(image_rels)} embedded image(s)")

    new_doc = Document()
    # Remove the default empty paragraph Word always adds
    for p in new_doc.paragraphs:
        p._element.getparent().remove(p._element)

    # Walk the document body in order (paragraphs AND tables, in sequence)
    body = doc.element.body
    para_count = 0
    table_count = 0
    image_count = 0

    print("\n📋 Recovering content...")

    for child in body:
        tag = child.tag.split("}")[-1] if "}" in child.tag else child.tag

        if tag == "p":
            # It's a paragraph
            from docx.text.paragraph import Paragraph
            src_para = Paragraph(child, doc)
            recover_paragraph(src_para, new_doc, image_rels)
            para_count += 1

        elif tag == "tbl":
            # It's a table
            from docx.table import Table
            src_table = Table(child, doc)
            recover_table(src_table, new_doc)
            table_count += 1

    print(f"  ✓ {para_count} paragraph(s) recovered")
    print(f"  ✓ {table_count} table(s) recovered")
    print(f"  ✓ {len(image_rels)} image(s) available (embedded inline where found)")

    new_doc.save(str(dst_path))
    print(f"\n✅ Clean document saved: {dst_path.resolve()}\n")


def _repair_and_open(src_path: Path) -> Document:
    """
    If the docx is a valid ZIP but has broken XML, copy it to a temp
    location, strip the corrupt content types, and try again.
    """
    with tempfile.TemporaryDirectory() as tmp:
        fixed = Path(tmp) / "fixed.docx"
        shutil.copy(src_path, fixed)
        # Just try opening the copy — sometimes the issue is a path/lock
        return Document(str(fixed))


# ── Entry point ───────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Recover all content from a corrupted .docx into a clean new file."
    )
    parser.add_argument("docx", help="Path to the corrupted .docx file")
    parser.add_argument(
        "--out", default=None,
        help="Output file path (default: <original>_recovered.docx)"
    )
    args = parser.parse_args()

    src = Path(args.docx)
    if not src.exists():
        print(f"❌ File not found: {src}")
        sys.exit(1)

    dst = Path(args.out) if args.out else src.with_name(src.stem + "_recovered.docx")

    recover(src, dst)


if __name__ == "__main__":
    main()
