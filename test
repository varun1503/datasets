# ══════════════════════════════════════════════════════════════════════════
#  2.  BUILD RAG PIPELINE
# ══════════════════════════════════════════════════════════════════════════
def build_rag_pipeline(documents: List[Document]):
    """Chunk docs → FAISS → RetrievalQA chain."""
    splitter = RecursiveCharacterTextSplitter(chunk_size=300, chunk_overlap=40)
    chunks = splitter.split_documents(documents)

    embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
    vectorstore = FAISS.from_documents(chunks, embeddings)
    retriever = vectorstore.as_retriever(search_kwargs={"k": 3})

    llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)
    qa_chain = RetrievalQA.from_chain_type(
        llm=llm,
        chain_type="stuff",
        retriever=retriever,
        return_source_documents=True,
    )
    return qa_chain, retriever


# ══════════════════════════════════════════════════════════════════════════
#  3.  RUN RAG  →  collect (question, answer, contexts, ground_truth)
# ══════════════════════════════════════════════════════════════════════════
def run_rag(qa_chain, eval_dataset: List[Dict]) -> List[Dict]:
    """Run each question through the RAG chain and collect results."""
    results = []
    for item in eval_dataset:
        question = item["question"]
        ground_truth = item["ground_truth"]

        response = qa_chain.invoke({"query": question})
        answer = response["result"]
        source_docs: List[Document] = response["source_documents"]
        contexts = [doc.page_content for doc in source_docs]

        results.append(
            {
                "question": question,
                "answer": answer,
                "contexts": contexts,
                "ground_truth": ground_truth,
            }
        )
        print(f"  Q: {question[:60]}...")
        print(f"  A: {answer[:100]}...\n")

    return results


# ══════════════════════════════════════════════════════════════════════════
#  4.  DEEPEVAL EVALUATION
# ══════════════════════════════════════════════════════════════════════════
def evaluate_with_deepeval(rag_results: List[Dict]) -> pd.DataFrame:
    """
    Runs DeepEval metrics:
      - Answer Relevancy
      - Faithfulness
      - Contextual Precision
      - Contextual Recall
      - Contextual Relevancy
    """
    print("\n" + "=" * 60)
    print("  DeepEval Evaluation")
    print("=" * 60)

    threshold = 0.5
    metrics = [
        AnswerRelevancyMetric(threshold=threshold, model="gpt-4o-mini"),
        FaithfulnessMetric(threshold=threshold, model="gpt-4o-mini"),
        ContextualPrecisionMetric(threshold=threshold, model="gpt-4o-mini"),
        ContextualRecallMetric(threshold=threshold, model="gpt-4o-mini"),
        ContextualRelevancyMetric(threshold=threshold, model="gpt-4o-mini"),
    ]

    test_cases = []
    for r in rag_results:
        test_cases.append(
            LLMTestCase(
                input=r["question"],
                actual_output=r["answer"],
                expected_output=r["ground_truth"],
                retrieval_context=r["contexts"],
            )
        )

    # Run evaluation
    evaluate(test_cases, metrics)

    # Collect per-question scores
    rows = []
    for tc, r in zip(test_cases, rag_results):
        row = {"question": r["question"][:55] + "..."}
        for m in metrics:
            name = type(m).__name__.replace("Metric", "")
            # score is available after evaluate()
            try:
                row[name] = round(m.score, 3)
            except Exception:
                row[name] = "N/A"
        rows.append(row)

    df = pd.DataFrame(rows)
    print("\nDeepEval Scores:")
    print(df.to_string(index=False))
    return df


# ══════════════════════════════════════════════════════════════════════════
#  5.  RAGAS EVALUATION
# ══════════════════════════════════════════════════════════════════════════
def evaluate_with_ragas(rag_results: List[Dict]) -> pd.DataFrame:
    """
    Runs RAGAS metrics:
      - Faithfulness
      - Answer Relevancy
      - Context Precision
      - Context Recall
      - Context Entity Recall
      - Answer Correctness
      - Answer Similarity
    """
    print("\n" + "=" * 60)
    print("  RAGAS Evaluation")
    print("=" * 60)

    # Build HuggingFace-style Dataset
    dataset = Dataset.from_dict(
        {
            "question": [r["question"] for r in rag_results],
            "answer": [r["answer"] for r in rag_results],
            "contexts": [r["contexts"] for r in rag_results],
            "ground_truth": [r["ground_truth"] for r in rag_results],
        }
    )

    llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)
    embeddings = OpenAIEmbeddings(model="text-embedding-3-small")

    ragas_llm = LangchainLLMWrapper(llm)
    ragas_emb = LangchainEmbeddingsWrapper(embeddings)

    ragas_metrics = [
        faithfulness,
        answer_relevancy,
        context_precision,
        context_recall,
        context_entity_recall,
        answer_correctness,
        answer_similarity,
    ]

    result = ragas_evaluate(
        dataset,
        metrics=ragas_metrics,
        llm=ragas_llm,
        embeddings=ragas_emb,
    )

    df = result.to_pandas()
    # Keep only score columns + question
    score_cols = [c for c in df.columns if c not in ("question", "answer", "contexts", "ground_truth")]
    display_cols = ["question"] + score_cols
    display_df = df[display_cols].copy()
    display_df["question"] = display_df["question"].str[:55] + "..."
    display_df[score_cols] = display_df[score_cols].round(3)

    print("\nRAGAS Scores:")
    print(display_df.to_string(index=False))

    # Aggregate means
    print("\nRAGAS Mean Scores:")
    print(df[score_cols].mean().round(3).to_string())

    return df


# ══════════════════════════════════════════════════════════════════════════
#  6.  COMBINED REPORT
# ══════════════════════════════════════════════════════════════════════════
def save_combined_report(
    rag_results: List[Dict],
    deepeval_df: pd.DataFrame,
    ragas_df: pd.DataFrame,
    path: str = "rag_eval_report.json",
) -> None:
    """Save all results to a JSON report."""

    def safe_dict(df: pd.DataFrame) -> List[Dict]:
        return json.loads(df.to_json(orient="records"))

    report = {
        "rag_results": [
            {k: v for k, v in r.items() if k != "contexts"} for r in rag_results
        ],
        "deepeval": safe_dict(deepeval_df),
        "ragas": safe_dict(ragas_df),
    }
    with open(path, "w") as f:
        json.dump(report, f, indent=2)
    print(f"\nCombined report saved to '{path}'")


