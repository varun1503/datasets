# Cell 2 - Imports
import subprocess
import os
from pathlib import Path
from IPython.display import FileLink, display
```

```python
# Cell 3 - Converter Function
def convert_docx_to_pdf(input_path: str, output_dir: str = ".") -> str:
    """
    Convert a .docx file to .pdf using LibreOffice.

    Args:
        input_path : Path to the .docx file
        output_dir : Directory to save the output PDF

    Returns:
        Path to the generated PDF file
    """
    input_path = str(input_path)

    if not os.path.exists(input_path):
        raise FileNotFoundError(f"❌ File not found: {input_path}")

    os.makedirs(output_dir, exist_ok=True)

    result = subprocess.run(
        [
            "libreoffice",
            "--headless",
            "--convert-to", "pdf",
            "--outdir", output_dir,
            input_path
        ],
        capture_output=True,
        text=True
    )

    if result.returncode != 0:
        raise RuntimeError(f"❌ Conversion failed:\n{result.stderr}")

    base_name = Path(input_path).stem
    output_path = os.path.join(output_dir, f"{base_name}.pdf")

    if not os.path.exists(output_path):
        raise FileNotFoundError(f"❌ Expected PDF not found: {output_path}")

    return output_path
```

```python
# Cell 4 - Run Conversion
# ✏️ Change these paths as needed
INPUT_DOCX  = "document.docx"   # Path to your .docx file
OUTPUT_DIR  = "./output"         # Folder to save the PDF

try:
    pdf_path = convert_docx_to_pdf(INPUT_DOCX, OUTPUT_DIR)
    size_kb = os.path.getsize(pdf_path) / 1024
    print(f"✅ Conversion successful!")
    print(f"📄 PDF saved to : {pdf_path}")
    print(f"📦 File size    : {size_kb:.1f} KB")
except FileNotFoundError as e:
    print(e)
except RuntimeError as e:
    print(e)
```

