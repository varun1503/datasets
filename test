from langchain_core.documents import Document
from langchain_openai import OpenAIEmbeddings  # or your embedding model
from langchain_community.vectorstores import FAISS  # or Chroma

# ── Step 1: Build LangChain Documents from your merged df ──
documents = []

for i, row in doc_df.iterrows():
    
    # Build readable content string from tuples
    content_parts = []
    for item in row["content"]:
        if isinstance(item, tuple):
            kind, val = item[0], item[1]
            if kind == "text":
                content_parts.append(str(val))
            elif kind == "table":
                # Convert table df to markdown string
                content_parts.append(val.to_markdown() if hasattr(val, "to_markdown") else str(val))
            elif kind == "image":
                content_parts.append("[IMAGE]")  # skip or add caption
        else:
            content_parts.append(str(item))
    
    full_content = "\n".join(content_parts).strip()
    
    if not full_content:
        continue

    doc = Document(
        page_content=full_content,
        metadata={
            "chunk_id": i,
            "section": row["section_name"] if pd.notna(row["section_name"]) else "Unknown",
            "word_count": len(full_content.split()),
            "has_table": any(isinstance(x, tuple) and x[0] == "table" for x in row["content"]),
            "has_image": any(isinstance(x, tuple) and x[0] == "image" for x in row["content"]),
        }
    )
    documents.append(doc)

print(f"Total LangChain documents: {len(documents)}")

# ── Step 2: Embed and store ──
embeddings = OpenAIEmbeddings(model="text-embedding-3-large")

vectorstore = FAISS.from_documents(documents, embeddings)
vectorstore.save_local("mrmg_index")  # save to disk

print("Vector store saved!")

# ── Step 3: Test retrieval with evidence ──
retriever = vectorstore.as_retriever(search_kwargs={"k": 3})

query = "What is the GMS exposure limit for small merchants?"
results = retriever.invoke(query)

for r in results:
    print(f"\n{'='*50}")
    print(f"Section  : {r.metadata['section']}")
    print(f"Chunk ID : {r.metadata['chunk_id']}")
    print(f"Has Table: {r.metadata['has_table']}")
    print(f"Content  : {r.page_content[:300]}")
```

