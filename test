The problem is clear. `create_or_update_footer` still uses `section.footer` which hits the same broken API. Here's your fully fixed file:

```python
from docx import Document
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.shared import Inches
from datetime import datetime
from docx.oxml import OxmlElement
from docx.oxml.ns import qn
from lxml import etree
from docx.opc.part import Part
from docx.opc.packuri import PackURI


class DocumentUpdater:

    def __init__(self, input_path, output_path):
        self.input_path = input_path
        self.output_path = output_path
        self.doc = Document(input_path)

    def _make_part(self, xml_bytes, part_type, rel_type, name_prefix, index):
        CT_MAP = {
            'header': 'application/vnd.openxmlformats-officedocument.wordprocessingml.header+xml',
            'footer': 'application/vnd.openxmlformats-officedocument.wordprocessingml.footer+xml',
        }
        REL_MAP = {
            'header': 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/header',
            'footer': 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/footer',
        }
        part_uri = PackURI(f'/word/{name_prefix}_custom_{index}.xml')
        part = Part(part_uri, CT_MAP[part_type], xml_bytes, self.doc.part.package)
        rId = self.doc.part.relate_to(part, REL_MAP[part_type])
        return rId

    def _remove_refs(self, sectPr, ref_tag):
        for ref in sectPr.findall(qn(ref_tag)):
            rId_old = ref.get(qn('r:id'))
            try:
                self.doc.part.drop_rel(rId_old)
            except:
                pass
            sectPr.remove(ref)

    def update_header(self, model_id, model_name):
        new_text = f"{model_id} {model_name} - Validation Report"
        W = 'http://schemas.openxmlformats.org/wordprocessingml/2006/main'
        R = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'

        hdr = etree.Element(f'{{{W}}}hdr', nsmap={'w': W, 'r': R})
        p = etree.SubElement(hdr, f'{{{W}}}p')
        pPr = etree.SubElement(p, f'{{{W}}}pPr')
        jc = etree.SubElement(pPr, f'{{{W}}}jc')
        jc.set(f'{{{W}}}val', 'center')
        pBdr = etree.SubElement(pPr, f'{{{W}}}pBdr')
        bottom = etree.SubElement(pBdr, f'{{{W}}}bottom')
        bottom.set(f'{{{W}}}val', 'single')
        bottom.set(f'{{{W}}}sz', '12')
        bottom.set(f'{{{W}}}space', '1')
        bottom.set(f'{{{W}}}color', '000000')
        r = etree.SubElement(p, f'{{{W}}}r')
        t = etree.SubElement(r, f'{{{W}}}t')
        t.text = new_text
        header_bytes = etree.tostring(hdr, xml_declaration=True,
                                      encoding='UTF-8', standalone=True)

        for i, section in enumerate(self.doc.sections):
            sectPr = section._sectPr
            self._remove_refs(sectPr, 'w:headerReference')
            rId = self._make_part(header_bytes, 'header', 'header', 'header', i + 1)
            hdrRef = OxmlElement('w:headerReference')
            hdrRef.set(qn('w:type'), 'default')
            hdrRef.set(qn('r:id'), rId)
            sectPr.insert(0, hdrRef)

    def create_or_update_footer(self, date=None):
        if date is None:
            date = datetime.now().strftime("%m/%d/%Y")

        W = 'http://schemas.openxmlformats.org/wordprocessingml/2006/main'
        R = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'

        for i, section in enumerate(self.doc.sections):
            page_width = section.page_width or Inches(8.5)
            left_margin = section.left_margin or Inches(1)
            right_margin = section.right_margin or Inches(1)
            section_width = int(page_width - left_margin - right_margin)

            # Build footer XML entirely with lxml — no section.footer access
            ftr = etree.Element(f'{{{W}}}ftr', nsmap={'w': W, 'r': R})

            # --- Top border paragraph ---
            p_border = etree.SubElement(ftr, f'{{{W}}}p')
            pPr_b = etree.SubElement(p_border, f'{{{W}}}pPr')
            pBdr = etree.SubElement(pPr_b, f'{{{W}}}pBdr')
            top = etree.SubElement(pBdr, f'{{{W}}}top')
            top.set(f'{{{W}}}val', 'single')
            top.set(f'{{{W}}}sz', '12')
            top.set(f'{{{W}}}space', '1')
            top.set(f'{{{W}}}color', '000000')

            # --- Table with 3 cols ---
            tbl = etree.SubElement(ftr, f'{{{W}}}tbl')
            tblPr = etree.SubElement(tbl, f'{{{W}}}tblPr')
            tblW = etree.SubElement(tblPr, f'{{{W}}}tblW')
            tblW.set(f'{{{W}}}w', str(section_width))
            tblW.set(f'{{{W}}}type', 'dxa')

            tblGrid = etree.SubElement(tbl, f'{{{W}}}tblGrid')
            col_width = str(section_width // 3)
            for _ in range(3):
                gridCol = etree.SubElement(tblGrid, f'{{{W}}}gridCol')
                gridCol.set(f'{{{W}}}w', col_width)

            tr = etree.SubElement(tbl, f'{{{W}}}tr')

            def make_cell(text, align, page_field=False):
                tc = etree.SubElement(tr, f'{{{W}}}tc')
                tcPr = etree.SubElement(tc, f'{{{W}}}tcPr')
                tcW = etree.SubElement(tcPr, f'{{{W}}}tcW')
                tcW.set(f'{{{W}}}w', col_width)
                tcW.set(f'{{{W}}}type', 'dxa')
                p = etree.SubElement(tc, f'{{{W}}}p')
                pPr = etree.SubElement(p, f'{{{W}}}pPr')
                jc = etree.SubElement(pPr, f'{{{W}}}jc')
                jc.set(f'{{{W}}}val', align)
                r = etree.SubElement(p, f'{{{W}}}r')
                t = etree.SubElement(r, f'{{{W}}}t')
                t.text = text
                if page_field:
                    # Add "Page " run + PAGE field
                    r2 = etree.SubElement(p, f'{{{W}}}r')
                    t2 = etree.SubElement(r2, f'{{{W}}}t')
                    t2.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
                    t2.text = 'Page '
                    # fldChar begin
                    r3 = etree.SubElement(p, f'{{{W}}}r')
                    fc1 = etree.SubElement(r3, f'{{{W}}}fldChar')
                    fc1.set(f'{{{W}}}fldCharType', 'begin')
                    # instrText
                    r4 = etree.SubElement(p, f'{{{W}}}r')
                    instr = etree.SubElement(r4, f'{{{W}}}instrText')
                    instr.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
                    instr.text = ' PAGE '
                    # fldChar end
                    r5 = etree.SubElement(p, f'{{{W}}}r')
                    fc2 = etree.SubElement(r5, f'{{{W}}}fldChar')
                    fc2.set(f'{{{W}}}fldCharType', 'end')
                    # Remove the empty first run
                    p.remove(r)

            make_cell(date, 'left')
            make_cell('AXP Internal', 'center')
            make_cell('', 'right', page_field=True)

            footer_bytes = etree.tostring(ftr, xml_declaration=True,
                                          encoding='UTF-8', standalone=True)

            sectPr = section._sectPr
            self._remove_refs(sectPr, 'w:footerReference')
            rId = self._make_part(footer_bytes, 'footer', 'footer', 'footer', i + 1)
            ftrRef = OxmlElement('w:footerReference')
            ftrRef.set(qn('w:type'), 'default')
            ftrRef.set(qn('r:id'), rId)
            sectPr.append(ftrRef)

    def process(self, model_id, model_name, date=None):
        self.update_header(model_id, model_name)
        self.create_or_update_footer(date)
        self.doc.save(self.output_path)
```

**Key change:** `create_or_update_footer` now also builds footer XML purely with lxml — completely avoiding `section.footer` which was hitting the same broken `'Part' object has no attribute 'element'` error. Neither header nor footer touch the python-docx section API at all now.
