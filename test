    # ==================================================================
    # 6. TEXT INSERTION UTILITY
    # ==================================================================

    def put_text(self, text, after, color=None):
        """
        Inserts a new paragraph of text into the document after a specific anchor.
        Can optionally color the text (e.g., 'FF00FF' for magenta).
        """
        self.move_cursor(to=after)
        if self._cursor is None:
            return

        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')
        
        # Create a clean new paragraph and text run
        new_p = etree.Element(f'{{{w}}}p')
        new_r = etree.Element(f'{{{w}}}r')
        
        # Apply color if specified
        if color:
            rPr = etree.Element(f'{{{w}}}rPr')
            color_elem = etree.Element(f'{{{w}}}color')
            
            # Convert standard names to hex if needed, Word prefers hex codes like 'FF00FF'
            if color.lower() == 'magenta':
                color_hex = 'FF00FF'
            elif color.lower() == 'red':
                color_hex = 'FF0000'
            else:
                color_hex = color
                
            color_elem.set(f'{{{w}}}val', color_hex)
            rPr.append(color_elem)
            new_r.append(rPr)
            
        # Add the text safely using the W3C namespace to prevent lxml crashes
        t = etree.Element(f'{{{w}}}t')
        t.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
        t.text = escape(text) if text else ""
        
        new_r.append(t)
        new_p.append(new_r)
        
        # Insert it into the document
        self._cursor.addnext(new_p)
        self._cursor = new_p
        
        # Save the changes to the XML
        etree.ElementTree(self._doc).write(
            os.path.join(self._path, 'word', 'document.xml'),
            **_XML_WRITE_KWARGS
        )
