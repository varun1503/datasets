    def move_cursor(self, to):
        """
        Moves the cursor to the paragraph containing the specific text.
        Crucially, it ensures we NEVER place the cursor inside or after 
        a master <w:sectPr> tag, which protects the headers and footers.
        """
        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')
        
        # Find the paragraph that contains our target text
        for p in self._doc.findall(f'.//{{{w}}}p'):
            texts = p.findall(f'.//{{{w}}}t')
            p_text = "".join([t.text for t in texts if t.text])
            
            if to in p_text:
                self._cursor = p
                
                # THE SHIELD: If this paragraph contains a section break, 
                # or is the very last paragraph of the document containing the master sectPr,
                # we must insert our new content BEFORE it, not after it.
                if p.find(f'.//{{{w}}}sectPr') is not None:
                    # We create a safe empty paragraph before the section break
                    # and move our cursor there.
                    safe_p = etree.Element(f'{{{w}}}p')
                    p.addprevious(safe_p)
                    self._cursor = safe_p
                    
                return
                
        self._cursor = None
