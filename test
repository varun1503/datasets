from lxml import etree
import difflib

def find_xml_bug(broken_xml_path, repaired_xml_path):
    print("🔍 Scanning for corrupted tags...\n")
    
    # 1. Load and automatically format both XML files
    parser = etree.XMLParser(remove_blank_text=True)
    broken_tree = etree.parse(broken_xml_path, parser)
    repaired_tree = etree.parse(repaired_xml_path, parser)

    broken_lines = etree.tostring(broken_tree, pretty_print=True, encoding='unicode').splitlines()
    repaired_lines = etree.tostring(repaired_tree, pretty_print=True, encoding='unicode').splitlines()

    # 2. Compare them and print only what Word deleted
    found_bug = False
    for line in difflib.unified_diff(broken_lines, repaired_lines, n=0):
        if line.startswith('- ') and not line.startswith('---'):
            print(f"❌ Word Deleted this tag: {line.strip()}")
            found_bug = True
            
    if not found_bug:
        print("✅ No differences found in this file.")

