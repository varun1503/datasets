#  8.  MAIN
# ══════════════════════════════════════════════════════════════════════════
def main():
    print(METRIC_REFERENCE)

    # Step 1 — Build RAG
    print("Building RAG pipeline ...")
    documents = get_documents()
    qa_chain, _ = build_rag_pipeline(documents)

