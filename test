@app.on_event("startup")
async def startup_event():
    print("=== STARTUP BEGIN ===", flush=True)
    logger.info("=== STARTUP BEGIN ===")

    # Step 1: Config
    try:
        print("STARTUP Step 1: Reading config...", flush=True)
        logger.info("STARTUP Step 1: Reading config...")
        app.state.config = read_config_set_env(app)
        logger.info(f"STARTUP Step 1: Config loaded successfully. Keys: {list(app.state.config.keys())}")
        print(f"STARTUP Step 1: Config loaded. Keys: {list(app.state.config.keys())}", flush=True)
    except Exception as e:
        logger.error(f"STARTUP FAILED at Step 1 (config): {e}")
        print(f"STARTUP FAILED at Step 1 (config): {e}", flush=True)
        raise

    # Step 2: Secrets
    try:
        print("STARTUP Step 2: Loading secrets...", flush=True)
        logger.info("STARTUP Step 2: Loading secrets...")
        app.state.secrets = Properties()
        secrets_path = app.state.config['DEFAULT']['SECRETS_PATH']
        logger.info(f"STARTUP Step 2: Secrets path = {secrets_path}")
        print(f"STARTUP Step 2: Secrets path = {secrets_path}", flush=True)
        with open(secrets_path, 'rb') as secrets_file:
            app.state.secrets.load(secrets_file)
        logger.info("STARTUP Step 2: Secrets loaded successfully")
        print("STARTUP Step 2: Secrets loaded successfully", flush=True)
    except FileNotFoundError as e:
        logger.error(f"STARTUP FAILED at Step 2 (secrets file not found): {e}")
        print(f"STARTUP FAILED at Step 2 (secrets file not found): {e}", flush=True)
        raise
    except Exception as e:
        logger.error(f"STARTUP FAILED at Step 2 (secrets): {e}")
        print(f"STARTUP FAILED at Step 2 (secrets): {e}", flush=True)
        raise

    # Step 3: ENV secrets to environment variables
    try:
        print("STARTUP Step 3: Setting env secrets...", flush=True)
        logger.info("STARTUP Step 3: Setting env secrets...")
        env = app.state.secrets.get("ENV").data
        logger.info(f"STARTUP Step 3: ENV = {env}")
        secrets_to_env(app.state.config)
        logger.info("STARTUP Step 3: Secrets applied to environment successfully")
        print("STARTUP Step 3: Secrets applied to environment", flush=True)
    except Exception as e:
        logger.error(f"STARTUP FAILED at Step 3 (env secrets): {e}")
        print(f"STARTUP FAILED at Step 3 (env secrets): {e}", flush=True)
        raise

    # Step 4: S3
    try:
        print("STARTUP Step 4: Initializing S3Utils...", flush=True)
        logger.info("STARTUP Step 4: Initializing S3Utils...")
        app.state.s3Utils = S3Utils(app.state.config["s3_details"], app.state.secrets)
        logger.info("STARTUP Step 4: S3Utils initialized successfully")
        print("STARTUP Step 4: S3Utils initialized successfully", flush=True)
    except Exception as e:
        logger.error(f"STARTUP FAILED at Step 4 (S3Utils): {e}")
        print(f"STARTUP FAILED at Step 4 (S3Utils): {e}", flush=True)
        raise

    # Step 5: Postgres
    try:
        print("STARTUP Step 5: Connecting to Postgres...", flush=True)
        logger.info("STARTUP Step 5: Connecting to Postgres...")
        db_user = app.state.secrets.get('POSTGRES_DB_USERNAME').data
        db_pass = app.state.secrets.get('POSTGRES_DB_PASSWORD').data
        db_host = app.state.config['HOSTNAME']
        db_name = app.state.config['DATABASE_NAME']
        database_url = (
            f"postgresql+psycopg2://{db_user}:{db_pass}"
            f"@{db_host}:5432/{db_name}"
            f"?connect_timeout=10"           # ← prevents infinite hang
        )
        logger.info(f"STARTUP Step 5: DB URL (masked) = postgresql+psycopg2://***@{db_host}:5432/{db_name}")
        print(f"STARTUP Step 5: DB URL host={db_host} db={db_name}", flush=True)

        engine = create_engine(
            database_url,
            pool_size=15,
            max_overflow=2,
            pool_recycle=1800,
            pool_pre_ping=True,
            pool_timeout=30
        )

        # Force a real connection test so we fail fast here, not at first request
        with engine.connect() as conn:
            conn.execute("SELECT 1")
        logger.info("STARTUP Step 5: Postgres connection verified")
        print("STARTUP Step 5: Postgres connection verified", flush=True)

        app.state.engine = engine
        session_local = sessionmaker(autocommit=False, autoflush=False, bind=engine)
        app.state.templates = StringTemplateQueryUtils(session_local)
        logger.info("STARTUP Step 5: SQLAlchemy session and templates ready")
        print("STARTUP Step 5: SQLAlchemy session and templates ready", flush=True)
    except Exception as e:
        logger.error(f"STARTUP FAILED at Step 5 (Postgres): {e}")
        print(f"STARTUP FAILED at Step 5 (Postgres): {e}", flush=True)
        raise

    logger.info("=== STARTUP COMPLETE — APP IS READY ===")
    print("=== STARTUP COMPLETE — APP IS READY ===", flush=True)


