    def update_index(self, content, index):
        """
        Merges content-type entries into [Content_Types].xml.
        Strictly prevents duplicate Extensions and PartNames to avoid corruption.
        """
        ct_path = os.path.join(self._path, '[Content_Types].xml')
        if not os.path.exists(ct_path):
            return
            
        idxdoc = etree.parse(ct_path).getroot()
        ct_ns = "http://schemas.openxmlformats.org/package/2006/content-types"
        
        # 1. Map out everything that ALREADY exists to guarantee no duplicates
        existing_exts = [el.get('Extension') for el in idxdoc.findall(f'.//{{{ct_ns}}}Default')]
        existing_parts = [el.get('PartName') for el in idxdoc.findall(f'.//{{{ct_ns}}}Override')]

        for k, xx in content['index'].items():
            local = etree.QName(xx).localname

            if local == 'Default':
                ext = xx.get('Extension')
                if ext and ext not in existing_exts:
                    # Build a perfectly clean tag
                    new_default = etree.Element(f'{{{ct_ns}}}Default', Extension=ext, ContentType=xx.get('ContentType'))
                    idxdoc.insert(0, new_default)
                    existing_exts.append(ext)

            elif local == 'Override':
                part_name = xx.get('PartName')
                if part_name:
                    # Update the path to match the newly copied media file
                    new_part_name = posixpath.dirname(part_name) + f'/copy{index}_' + posixpath.basename(part_name)
                    
                    if new_part_name not in existing_parts:
                        new_override = etree.Element(f'{{{ct_ns}}}Override', PartName=new_part_name, ContentType=xx.get('ContentType'))
                        idxdoc.append(new_override)
                        existing_parts.append(new_part_name)

        # Save the completely clean and deduplicated index
        etree.ElementTree(idxdoc).write(ct_path, **_XML_WRITE_KWARGS)
