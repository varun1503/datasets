    best_match = None
    best_text = None
    best_score = 0

    for xx in self._doc.xpath('./w:body/w:p', namespaces=self._doc.nsmap):

        # ✅ Get processed text ONCE
        raw_text = get_text(xx, self._doc.nsmap)

        if not raw_text:
            continue

        # ✅ Skip unwanted outline levels
        olvl = self.get_outline_level(xx)
        if olvl in (-1, 9):
            continue

        doc_section = extract_section_number(raw_text)
        doc_title = clean_text(remove_section_number(raw_text))

        # =========================
        # ✅ STRICT MATCH (FIXED)
        # =========================
        if input_section:
            if doc_section != input_section:
                continue   # 🔥 Prevent 10 → 46 issue

        # ✅ Exact match
        if input_section and doc_section and input_section == doc_section:
            print("✅ Exact match found")
            self._cursor = xx
            return raw_text

        # =========================
        # ✅ Fuzzy match
        # =========================
        score = fuzz.token_set_ratio(input_title, doc_title)

        if score > best_score:
            best_score = score
            best_match = xx
            best_text = raw_text

    # =========================
    # ✅ Final result
    # =========================
    if best_match is not None and best_score >= 85:
        print("✅ Best match selected")
        print("SECTION:", best_text)
        print("SCORE:", best_score)

        self._cursor = best_match
        return best_text

    print("❌ No matching section found")
    return ""
