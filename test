    def validate_xml_parts(self):
        """
        Walks every XML/rels file in the unpacked docx folder.
        Prints which files are broken or missing declaration.
        Call this before save() to catch issues early.
        """
        print('\n── Pre-save XML validation ──')
        found_error       = False
        missing_decl      = []
        syntax_errors     = []

        for foldername, _, filenames in os.walk(self._path):
            for filename in filenames:
                if not (
                    filename.endswith('.xml')
                    or filename.endswith('.rels')
                ):
                    continue

                path = os.path.join(foldername, filename)

                # check declaration
                with open(path, 'rb') as f:
                    header = f.read(60)
                if not header.startswith(b'<?xml'):
                    missing_decl.append(path)
                    found_error = True

                # check parse
                try:
                    etree.parse(path)
                except etree.XMLSyntaxError as e:
                    syntax_errors.append((path, str(e)))
                    found_error = True

        if missing_decl:
            print(f'  ❌ Missing XML declaration ({len(missing_decl)} files):')
            for p in missing_decl:
                print(f'     • {os.path.relpath(p, self._path)}')

        if syntax_errors:
            print(f'  ❌ XML syntax errors ({len(syntax_errors)} files):')
            for p, e in syntax_errors:
                print(f'     • {os.path.relpath(p, self._path)}: {e}')

        if not found_error:
            print('  ✅ All XML parts valid — safe to save')

        return not found_error

    # ─────────────────────────────────────────────────────────
    def save(self, filepath=''):
        filepath = self._path + '.docx' if filepath == '' else filepath

        if os.path.exists(filepath):
            os.remove(filepath)

        # ── validate before zipping ───────────────────────────
        is_valid = self.validate_xml_parts()
        if not is_valid:
            print(
                '  ⚠️  Saving anyway — open the file in Word '
                'and click Yes to recover, then re-check.'
            )

        # ── collect all files ─────────────────────────────────
        no_compress = {
            '.png', '.jpg', '.jpeg', '.gif',
            '.wmf', '.emf', '.bin'
        }
        all_files = []
        for foldername, _, filenames in os.walk(self._path):
            for filename in filenames:
                file_path = os.path.join(foldername, filename)
                arcname   = os.path.relpath(
                    file_path, self._path
                ).replace(os.sep, '/')
                all_files.append((file_path, arcname))

        # ✅ [Content_Types].xml MUST be first entry in ZIP
        def sort_key(item):
            a = item[1]
            if a == '[Content_Types].xml':  return 0
            if a.startswith('_rels/'):      return 1
            if a.startswith('word/_rels/'): return 2
            if a == 'word/document.xml':    return 3
            return 10

        all_files.sort(key=sort_key)

        # ✅ allowZip64=False — Word rejects ZIP64 format
        with zipfile.ZipFile(
            filepath, 'w',
            zipfile.ZIP_DEFLATED,
            allowZip64=False
        ) as docx:
            for file_path, arcname in all_files:
                ext      = os.path.splitext(file_path)[1].lower()
                compress = (
                    zipfile.ZIP_STORED
                    if ext in no_compress
                    else zipfile.ZIP_DEFLATED
                )
                docx.write(file_path, arcname, compress_type=compress)

        print(f'\n  ✅ Saved: {filepath}')
        return filepath
