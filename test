# ---------------------------------------------------------------------------
# Lifespan – replaces deprecated @app.on_event("startup") / ("shutdown")
# ---------------------------------------------------------------------------
@asynccontextmanager
async def lifespan(app: FastAPI):
    # ── STARTUP ──────────────────────────────────────────────────────────────
    app.state.config = read_config_set_env(app)
    app.state.secrets = Properties()

    with open(app.state.config["DEFAULT"]["SECRETS_PATH"], "rb") as secrets_file:
        app.state.secrets.load(secrets_file)

    secrets_to_env(app.state.config)
    app.state.s3Utils = S3Utils(app.state.config["s3_details"], app.state.secrets)

    database_url = (
        f"postgresql+psycopg2://"
        f"{app.state.secrets.get('POSTGRES_DB_USERNAME').data}:"
        f"{app.state.secrets.get('POSTGRES_DB_PASSWORD').data}@"
        f"{app.state.config['HOSTNAME']}:5432/"
        f"{app.state.config['DATABASE_NAME']}"
    )

    logger.info("Creating Postgres Engine...")
    engine = create_engine(
        database_url,
        pool_size=15,
        max_overflow=2,
        pool_recycle=1800,
        pool_pre_ping=True,
        pool_timeout=30,
    )
    app.state.engine = engine

    SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)
    app.state.SessionLocal = SessionLocal
    app.state.templates = StringTemplateQueryUtils(SessionLocal)
    logger.info("Postgres Engine created successfully")

    yield  # ── application runs here ──────────────────────────────────────

    # ── SHUTDOWN ─────────────────────────────────────────────────────────────
    logger.info("Application Shutdown")
    if hasattr(app.state, "engine"):
        try:
            app.state.engine.dispose()
            logger.info("SQLAlchemy engine disposed cleanly on shutdown")
        except Exception as e:
            logger.error(f"Error disposing engine: {e}")


# ---------------------------------------------------------------------------
# App initialisation
# ---------------------------------------------------------------------------
app = FastAPI(lifespan=lifespan)

# Only 1 worker per POD — keeps the pod single-tenant for heavy ML tasks
executor = ThreadPoolExecutor(max_workers=1)

# Use a threading.Event (correct primitive for threads; multiprocessing.Value
# is only needed when sharing state across OS-level processes)
_busy_event = threading.Event()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)


# ---------------------------------------------------------------------------
# Dependency helpers
# ---------------------------------------------------------------------------
def get_config(request: Request) -> dict:
    return request.app.state.config


def get_s3(request: Request):
    return request.app.state.s3Utils


def get_db(request: Request) -> Session:
    """Yield a per-request DB session and close it when the request is done."""
    SessionLocal = request.app.state.SessionLocal
    db: Session = SessionLocal()
    try:
        yield db
    finally:
        db.close()


# ---------------------------------------------------------------------------
# Middleware
# ---------------------------------------------------------------------------
@app.middleware("http")
async def log_requests(request: Request, call_next):
    skip = request.url.path == "/liveness"
    if not skip:
        logger.info(f"Request: {request.method} {request.url}")
    response = await call_next(request)
    if not skip:
        logger.info(f"STATUS_CODE: {response.status_code}")
    if app_env != "e0" and request.url.path not in ["/docs", "/openapi.json"]:
        try:
            asyncio.create_task(asyncio.to_thread(logger_provider.force_flush))
        except Exception:
            pass
    return response


# ---------------------------------------------------------------------------
# Health / readiness probes  (split so k8s can distinguish them)
# ---------------------------------------------------------------------------
@app.get("/liveness", tags=["ops"])
async def liveness():
    """Liveness probe – is the container alive?"""
    return {"status": "ok"}


@app.get("/readiness", tags=["ops"])
async def readiness():
    """Readiness probe – can the pod accept new requests?"""
    if _busy_event.is_set():
        raise HTTPException(status_code=503, detail="Pod is busy – try another instance")
    return {"status": "ready"}


# Keep the old name alive so existing callers aren't broken
@app.get("/gdhahealthcheck", tags=["ops"], deprecated=True)
async def gdhahealthcheck():
    return await readiness()


@app.get("/", tags=["ops"])
async def home():
    logger.info("default endpoint hit")
    return {"response": "Home Page"}


