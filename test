**Fix 2 — `update_index`: don't mutate `xx` before existence check**

```python
def update_index(self, content, index):
    idxdoc = etree.parse(os.path.join(self._path, '[Content_Types].xml')).getroot()

    for k, xx in content['index'].items():
        if etree.QName(xx).localname == 'Default':
            if idxdoc.find(f'./*[@Extension="{k}"]') is None:
                idxdoc.insert(0, xx)

        elif etree.QName(xx).localname == 'Override':
            # ✅ Build the new key BEFORE mutating xx
            new_key = os.path.dirname(k) + f'/copy{index}_' + os.path.basename(k)
            if idxdoc.find(f'./*[@PartName="{new_key}"]') is None:
                # ✅ Clone so you don't corrupt the original
                xx_copy = etree.fromstring(etree.tostring(xx))
                xx_copy.set('PartName', new_key)
                idxdoc.append(xx_copy)

    etree.ElementTree(idxdoc).write(
        os.path.join(self._path, '[Content_Types].xml'), pretty_print=True
    )
```

