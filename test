Here's the modified `build_documents` where tables are converted to string and combined with text for richer retrieval context:

```python
from langchain_core.documents import Document
import pandas as pd
import json

def build_documents(
    doc_df,
    section_col="section_name",
    text_col="paragraph_content",
    content_col="content",
    type_col="type",
    image_col="image_base64",
    table_col="table_data",
):
    def safe_text(x):
        if x is None or (not isinstance(x, (list, tuple)) and pd.isna(x)):
            return ""
        return str(x)

    def safe_val(x):
        if x is None:
            return None
        try:
            if pd.isna(x):
                return None
        except Exception:
            pass
        return x

    def table_to_string(table_data):
        """
        Convert any table format into a rich readable string
        for better retrieval context.
        """
        try:
            # ── list of dicts → markdown + key:value sentences ────────────
            if isinstance(table_data, list) and all(isinstance(r, dict) for r in table_data):
                table_df = pd.DataFrame(table_data)

                # Markdown table
                markdown = table_df.to_markdown(index=False)

                # Key:value sentence per row for semantic retrieval
                sentences = []
                for i, r in enumerate(table_data):
                    row_str = ", ".join(f"{k} is {v}" for k, v in r.items() if v not in (None, "", "nan"))
                    if row_str:
                        sentences.append(f"Row {i+1}: {row_str}.")

                return markdown + "\n\n" + "\n".join(sentences)

            # ── dict → single row ──────────────────────────────────────────
            elif isinstance(table_data, dict):
                row_str = ", ".join(f"{k} is {v}" for k, v in table_data.items() if v not in (None, "", "nan"))
                table_df = pd.DataFrame([table_data])
                markdown = table_df.to_markdown(index=False)
                return markdown + "\n\n" + row_str

            # ── nested list (rows of lists) ────────────────────────────────
            elif isinstance(table_data, list) and all(isinstance(r, list) for r in table_data):
                if len(table_data) >= 2:
                    headers = table_data[0]
                    rows    = table_data[1:]
                    table_df = pd.DataFrame(rows, columns=headers)
                    markdown = table_df.to_markdown(index=False)

                    sentences = []
                    for i, row in enumerate(rows):
                        row_str = ", ".join(
                            f"{headers[j]} is {row[j]}"
                            for j in range(min(len(headers), len(row)))
                            if row[j] not in (None, "", "nan")
                        )
                        if row_str:
                            sentences.append(f"Row {i+1}: {row_str}.")
                    return markdown + "\n\n" + "\n".join(sentences)
                else:
                    return str(table_data)

            # ── JSON string ────────────────────────────────────────────────
            elif isinstance(table_data, str):
                try:
                    parsed = json.loads(table_data)
                    return table_to_string(parsed)   # recurse with parsed
                except Exception:
                    return table_data                # already a plain string

            else:
                return str(table_data)

        except Exception as e:
            return str(table_data)

    documents  = []
    text_count = 0
    table_count = 0
    image_count = 0

    for chunk_id, row in doc_df.iterrows():

        section    = safe_val(row.get(section_col))
        raw_text   = safe_text(row.get(text_col, ""))
        content    = row.get(content_col, [])
        row_type   = safe_val(row.get(type_col))
        image_b64  = safe_val(row.get(image_col))
        table_data = safe_val(row.get(table_col))

        # ── Auto detect type ──────────────────────────────────────────────
        if row_type is None:
            if image_b64:
                row_type = "image"
            elif table_data is not None:
                row_type = "table"
            else:
                row_type = "text"

        # ── Build page_content ────────────────────────────────────────────
        if row_type == "image":
            # Include surrounding text as caption for context
            page_content = f"[IMAGE]\n{raw_text}".strip() if raw_text else "[IMAGE]"
            image_count += 1

        elif row_type == "table":
            # Convert table to rich string
            table_str = table_to_string(table_data)

            # Structure: section heading + surrounding text + table string
            # This gives retrieval maximum context
            parts = []

            if section:
                parts.append(f"Section: {section}")

            if raw_text:
                parts.append(f"Context: {raw_text}")

            parts.append(f"Table:\n{table_str}")

            page_content = "\n\n".join(parts)
            table_count += 1

        else:  # text
            page_content = raw_text
            text_count += 1

        # ── Skip empty ────────────────────────────────────────────────────
        if not page_content.strip():
            continue

        # ── Metadata ──────────────────────────────────────────────────────
        metadata = {
            "chunk_id"  : chunk_id,
            "section"   : section if section else "unknown",
            "type"      : row_type,
            "has_image" : image_b64 is not None,
            "has_table" : table_data is not None,
        }

        if image_b64:
            metadata["image_base64"] = image_b64

        # Store original raw table in metadata for reference
        if table_data is not None:
            metadata["table_data"] = table_data

        if isinstance(content, list) and len(content) > 0:
            metadata["content"] = content

        documents.append(Document(page_content=page_content, metadata=metadata))

    print(f"Text: {text_count} | Table: {table_count} | Image: {image_count}")
    return documents


# ── Usage ─────────────────────────────────────────────────────────────────────

doc_df    = merge_sections(df)
documents = build_documents(doc_df)

# Preview table documents
for doc in documents:
    if doc.metadata["type"] == "table":
        print("\n===== TABLE DOCUMENT =====")
        print(doc.page_content)
        print("==========================")
```

What changed for table `page_content`:

```
Section: Business Problem solved by Non-Model Tool

Context: The following table shows exposure limits by region.

Table:
| Region | Limit | Currency |
|--------|-------|----------|
| US     | 500   | USD      |
| EU     | 300   | EUR      |

Row 1: Region is US, Limit is 500, Currency is USD.
Row 2: Region is EU, Limit is 300, Currency is EUR.
```

This means when retrieval happens, the query matches against section name + surrounding text + table content all together, giving much richer context than a plain markdown table alone.
