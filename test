Here's a separate clean `build_documents` function that takes the merged `doc_df`:

```python
from langchain_core.documents import Document
import pandas as pd

def build_documents(
    doc_df,
    section_col="section_name",
    text_col="paragraph_content",
    content_col="content",
    type_col="type",
    image_col="image_base64",
    table_col="table_data",
):
    def safe_text(x):
        if x is None or (not isinstance(x, (list, tuple)) and pd.isna(x)):
            return ""
        return str(x)

    def safe_val(x):
        if x is None:
            return None
        try:
            if pd.isna(x):
                return None
        except Exception:
            pass
        return x

    documents = []
    text_count = 0
    table_count = 0
    image_count = 0

    for chunk_id, row in doc_df.iterrows():

        section    = safe_val(row.get(section_col))
        raw_text   = safe_text(row.get(text_col, ""))
        content    = row.get(content_col, [])
        row_type   = safe_val(row.get(type_col))
        image_b64  = safe_val(row.get(image_col))
        table_data = safe_val(row.get(table_col))

        # ── Detect type if not explicitly set ─────────────────────────────
        if row_type is None:
            if image_b64:
                row_type = "image"
            elif table_data:
                row_type = "table"
            else:
                row_type = "text"

        # ── Build page_content based on type ──────────────────────────────
        if row_type == "image":
            page_content = raw_text if raw_text else "[IMAGE]"
            image_count += 1

        elif row_type == "table":
            if isinstance(table_data, list):
                # list of dicts → markdown table
                table_df = pd.DataFrame(table_data)
                page_content = table_df.to_markdown(index=False)
            elif isinstance(table_data, dict):
                table_df = pd.DataFrame([table_data])
                page_content = table_df.to_markdown(index=False)
            else:
                page_content = safe_text(table_data)
            # Append any caption/text below table
            if raw_text:
                page_content = f"{page_content}\n\n{raw_text}"
            table_count += 1

        else:  # text
            page_content = raw_text
            text_count += 1

        # ── Skip empty documents ──────────────────────────────────────────
        if not page_content.strip():
            continue

        # ── Build metadata ────────────────────────────────────────────────
        metadata = {
            "chunk_id"  : chunk_id,
            "section"   : section if section else "unknown",
            "type"      : row_type,
            "has_image" : image_b64 is not None,
            "has_table" : table_data is not None,
        }

        # Attach base64 image to metadata if present
        if image_b64:
            metadata["image_base64"] = image_b64

        # Attach raw table to metadata if present
        if table_data is not None:
            metadata["table_data"] = table_data

        # Attach content list to metadata if present
        if isinstance(content, list) and len(content) > 0:
            metadata["content"] = content

        # ── Create Document ───────────────────────────────────────────────
        doc = Document(
            page_content=page_content,
            metadata=metadata
        )
        documents.append(doc)

    print(f"Text: {text_count} | Table: {table_count} | Image: {image_count}")
    return documents


# ── Usage ─────────────────────────────────────────────────────────────────────

doc_df   = merge_sections(df)
documents = build_documents(doc_df)

print(f"Total documents: {len(documents)}")

# Preview first 3
for doc in documents[:3]:
    print("\n--- Document ---")
    print(f"Section : {doc.metadata['section']}")
    print(f"Type    : {doc.metadata['type']}")
    print(f"Has Image: {doc.metadata['has_image']}")
    print(f"Has Table: {doc.metadata['has_table']}")
    print(f"Content : {doc.page_content[:200]}")
```

How each type is handled:

| Type | `page_content` | Metadata extras |
|---|---|---|
| `text` | Raw paragraph text | — |
| `table` | Markdown table + caption | `table_data` (raw) |
| `image` | Caption/alt text or `[IMAGE]` | `image_base64` |

If your columns have different names, just pass them in:
```python
documents = build_documents(
    doc_df,
    section_col="section_name",
    image_col="img_b64",
    table_col="tbl"
)
```
