@app.post("/validation_report_vr")
async def validation_report_vr(request: Request, payload: ValidationReportInput):
    if is_busy.value:
        raise HTTPException(status_code=429, detail="POD is busy")
    try:
        logger.info(f"/validation_report_vr payload received - {dict(payload)}")
        output = dict(payload)
        results = [dict(item) for item in output["imvp_details"]]
        df = pd.DataFrame(results)
        task_wrapper(request, app.state.config, payload, df)
        return "API triggered successfully"
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"/validation_report_vr Exception: {e}")
        raise


def fire_and_forget(request, config, payload, df):
    """
    Alternative: plain thread instead of ThreadPoolExecutor.
    Kept for reference but task_wrapper is preferred.
    """
    thread = threading.Thread(target=mrmg_execute_vr, args=(request, config, payload, df))
    thread.daemon = True
    thread.start()


