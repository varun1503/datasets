def get_text(p, nsmap, resolver=None):
    texts = []

    for x in p.xpath('.//w:t', namespaces=nsmap):
        if x.text:
            texts.append(x.text)

    full_text = ''.join(texts).strip()

    # ✅ If already numbered → keep
    if re.match(r'^\d+(\.\d+)*\.?\s+', full_text):
        return full_text

    # ✅ Try resolving numbering (FIXED PATH)
    numPr = p.find('./w:pPr/w:numPr', namespaces=nsmap)

    if numPr is not None and resolver is not None:
        numId_el = numPr.find('./w:numId', namespaces=nsmap)
        ilvl_el = numPr.find('./w:ilvl', namespaces=nsmap)

        if numId_el is not None and ilvl_el is not None:
            numId = numId_el.get(f"{{{nsmap['w']}}}val")
            ilvl = int(ilvl_el.get(f"{{{nsmap['w']}}}val"))

            number = resolver.get_number(numId, ilvl)

            if number:
                return f"{number} {full_text}"

    return full_text
