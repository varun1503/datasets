def _build_numbering_map(self):
    from collections import defaultdict
    ns = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')
    ns_uri = f'{{{ns}}}'
    counters = defaultdict(int)
    numbering_map = {}

    for p in self._doc.xpath('.//w:body/w:p', namespaces=self._doc.nsmap):
        numPr = p.find(f'.//{ns_uri}numPr')
        if numPr is not None:
            ilvl_el = numPr.find(f'{ns_uri}ilvl')
            numId_el = numPr.find(f'{ns_uri}numId')
            if ilvl_el is not None and numId_el is not None:
                lvl = ilvl_el.get(f'{ns_uri}val')
                nid = numId_el.get(f'{ns_uri}val')
                counters[(nid, lvl)] += 1
                numbering_map[id(p)] = counters[(nid, lvl)]

    return numbering_map
```

