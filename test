# ---------------------------------------------------------------------------
# Self-test — run:  python move_cursor_optimized.py
# ---------------------------------------------------------------------------
if __name__ == '__main__':
    logging.basicConfig(level=logging.DEBUG)
    ok = True

    CHILD_TESTS = [
        ((3, 2, 1),    (3, 2),   True),
        ((3, 2, 1, 1), (3, 2),   True),
        ((3, 3),       (3, 2),   False),
        ((3, 2),       (3, 2),   False),   # same is NOT a child
        ((4, 1),       (3, 2),   False),
        ((11, 1, 1),   (11, 1),  True),
        ((11, 2),      (11, 1),  False),
    ]
    print("=== _is_child_of ===")
    for child, parent, expected in CHILD_TESTS:
        result = _is_child_of(child, parent)
        status = "PASS" if result == expected else "FAIL"
        if status == "FAIL":
            ok = False
        print(f"  [{status}]  _is_child_of({child}, {parent}) = {result}  (expected {expected})")

    SIBLING_TESTS = [
        ((3, 3),    (3, 2),  True),    # next sibling  -> stop
        ((3, 2),    (3, 2),  True),    # same section  -> stop
        ((4,),      (3, 2),  True),    # higher level  -> stop
        ((3, 2, 1), (3, 2),  False),   # child         -> keep
        ((3, 2, 1, 1), (3,2),False),   # grandchild    -> keep
    ]
    print("\n=== _is_next_sibling_or_above ===")
    for cand, anchor, expected in SIBLING_TESTS:
        result = _is_next_sibling_or_above(cand, anchor)
        status = "PASS" if result == expected else "FAIL"
        if status == "FAIL":
            ok = False
        print(f"  [{status}]  sibling_or_above({cand}, anchor={anchor}) = {result}  (expected {expected})")

    PARSE_TESTS = [
        ("3.2 Title",   (3, 2)),
        ("11.1.4 Foo",  (11, 1, 4)),
        ("No number",   None),
        ("",            None),
    ]
    print("\n=== _parse_section ===")
    for s, expected in PARSE_TESTS:
        result = _parse_section(s)
        status = "PASS" if result == expected else "FAIL"
        if status == "FAIL":
            ok = False
        print(f"  [{status}]  _parse_section({s!r}) = {result}  (expected {expected})")

    print(f"\n{'All tests passed!' if ok else 'SOME TESTS FAILED — check above.'}")
