    # ------------------------------------------------------------------
    # Auto-Router: Chooses between Full Paste and Text-Only Paste
    # ------------------------------------------------------------------

    def paste_content_auto(self, content, after, index):
        """
        Pre-scans the section's XML. If it detects tags that are notorious 
        for causing Word corruption (images, charts, hyperlinks, objects), 
        it safely falls back to paste_content_text_only. 
        Otherwise, it runs the standard paste_content.
        """
        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')
        
        # 1. Define the "Red Flags" that cause Word to corrupt
        dangerous_tags = [
            f'{{{w}}}drawing',          # Charts and modern images
            f'{{{w}}}pict',             # Older shapes and VML images
            f'{{{w}}}object',           # Embedded files (like Excel or PDF)
            f'{{{w}}}hyperlink',        # Web links that require a .rels ID
            f'{{{w}}}commentReference'  # Comments linked to other users
        ]
        
        might_corrupt = False
        
        # 2. Pre-scan all paragraphs in this section
        for c in content['data']:
            for tag in dangerous_tags:
                if c.find(f'.//{tag}') is not None:
                    might_corrupt = True
                    break  # Stop checking this paragraph
            
            if might_corrupt:
                break  # Stop checking the rest of the section, we know it's dangerous

        # 3. Route to the appropriate function based on the scan
        if might_corrupt:
            # Danger detected: Fall back to the safe text-only/table rebuild method
            print(f"⚠️ Risk detected near '{after}'. Falling back to Text-Only paste.")
            self.paste_content_text_only(content, after, index)
        else:
            # Safe section: Proceed with the standard full-format paste
            print(f"✅ Safe section near '{after}'. Using Standard paste.")
            self.paste_content(content, after, index)
