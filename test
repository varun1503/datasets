# ─────────────────────────────────────────────
# DOCX CORRUPTION VALIDATOR
# ─────────────────────────────────────────────

import zipfile
from lxml import etree
import os

# Required XML parts that must exist and parse cleanly
CRITICAL_PARTS = [
    'word/document.xml',
    'word/_rels/document.xml.rels',
    '[Content_Types].xml',
    'word/styles.xml',
]

OPTIONAL_PARTS = [
    'word/numbering.xml',
    'word/settings.xml',
]


def validate_docx(filepath):
    """
    Validates a .docx file before processing.

    Returns:
        (is_valid: bool, reasons: list[str])

    Usage:
        is_valid, reasons = validate_docx("myfile.docx")
        if not is_valid:
            print(f"CORRUPT: {reasons}")
    """
    reasons = []

    # ── 1. File existence & extension ──────────────────────────
    if not os.path.exists(filepath):
        return False, ["File does not exist"]

    if not filepath.lower().endswith('.docx'):
        return False, ["Not a .docx file"]

    if os.path.getsize(filepath) == 0:
        return False, ["File is empty (0 bytes)"]

    # ── 2. Valid ZIP structure ──────────────────────────────────
    if not zipfile.is_zipfile(filepath):
        return False, ["Not a valid ZIP/docx archive"]

    try:
        zf = zipfile.ZipFile(filepath, 'r')
    except zipfile.BadZipFile as e:
        return False, [f"BadZipFile: {e}"]

    with zf:
        zip_names = zf.namelist()

        # ── 3. Critical parts must exist ───────────────────────
        for part in CRITICAL_PARTS:
            if part not in zip_names:
                reasons.append(f"Missing critical part: {part}")

        if reasons:
            return False, reasons  # stop early — no point parsing

        # ── 4. Critical XML must parse cleanly ─────────────────
        for part in CRITICAL_PARTS:
            try:
                with zf.open(part) as f:
                    etree.parse(f)
            except etree.XMLSyntaxError as e:
                reasons.append(f"XML syntax error in {part}: {e}")
            except Exception as e:
                reasons.append(f"Cannot read {part}: {e}")

        # ── 5. Optional parts — warn but don't fail ────────────
        warnings = []
        for part in OPTIONAL_PARTS:
            if part in zip_names:
                try:
                    with zf.open(part) as f:
                        etree.parse(f)
                except etree.XMLSyntaxError as e:
                    warnings.append(f"XML warning in {part}: {e}")

        # ── 6. Relationships must reference existing parts ─────
        try:
            with zf.open('word/_rels/document.xml.rels') as f:
                reldoc = etree.parse(f).getroot()
            for rel in reldoc.findall('./'):
                target = rel.get('Target', '')
                mode = rel.get('TargetMode', '')
                if mode == 'External':
                    continue
                full = f"word/{target}" if not target.startswith('/') else target.lstrip('/')
                if full not in zip_names:
                    warnings.append(f"Relationship target missing: {full}")
        except Exception:
            pass  # already caught above

    if reasons:
        return False, reasons

    return True, warnings  # valid; warnings may still be populated


# ─────────────────────────────────────────────
# FLAG + SKIP WRAPPER  — plug into your loop
# ─────────────────────────────────────────────

def process_documents(file_list):
    """
    Wraps your Document1 / ModelDoc / ValReport instantiation.
    Flags corrupt files and skips them automatically.
    """
    corrupt_log = []   # collects all flagged files
    processed   = []
    skipped     = []

    for filepath in file_list:
        is_valid, issues = validate_docx(filepath)

        if not is_valid:
            # ── FLAG it ────────────────────────────────────────
            corrupt_log.append({
                'file':   filepath,
                'issues': issues,
            })
            skipped.append(filepath)
            print(f"[CORRUPT ✗] {os.path.basename(filepath)}")
            for issue in issues:
                print(f"            └─ {issue}")
            continue  # ← STOP EXECUTION for this file

        if issues:  # warnings only
            print(f"[WARN    ⚠] {os.path.basename(filepath)}")
            for w in issues:
                print(f"            └─ {w}")

        # ── Safe to process ────────────────────────────────────
        try:
            print(f"[OK      ✓] {os.path.basename(filepath)}")
            doc = ModelDoc(filepath)       # or ValReport(filepath)
            processed.append(filepath)
            # ... rest of your logic here ...

        except Exception as e:
            # catches runtime corruption not caught by validator
            corrupt_log.append({'file': filepath, 'issues': [str(e)]})
            skipped.append(filepath)
            print(f"[RUNTIME ✗] {os.path.basename(filepath)}: {e}")

    # ── Summary report ─────────────────────────────────────────
    print(f"\n{'─'*50}")
    print(f"  Processed : {len(processed)}")
    print(f"  Skipped   : {len(skipped)}")
    print(f"  Corrupt   : {len(corrupt_log)}")
    print(f"{'─'*50}")

    if corrupt_log:
        print("\nCorrupt file details:")
        for entry in corrupt_log:
            print(f"  • {entry['file']}")
            for issue in entry['issues']:
                print(f"      - {issue}")

    return processed, corrupt_log


