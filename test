# ─────────────────────────────────────────────────────────────
# CHART COPY VERIFIER
# Run this AFTER paste_content() and BEFORE save()
# to confirm all chart deps copied correctly
# ─────────────────────────────────────────────────────────────

import os
import zipfile
from lxml import etree


def verify_chart_copy(val_report_path):
    """
    Checks the unpacked ValReport folder (before save)
    to confirm every chart's dependencies are present.

    val_report_path : ValReport._path  (the temp folder)

    Usage:
        val = ValReport(...)
        val.paste_content(...)
        verify_chart_copy(val._path)   # ← run before save()
        val.save(...)
    """
    charts_dir = os.path.join(val_report_path, 'word', 'charts')
    rels_dir   = os.path.join(charts_dir, '_rels')

    if not os.path.exists(charts_dir):
        print("❌ No charts directory found")
        return False

    # ── Collect all chart xml files ───────────────────────────
    chart_files = [
        f for f in os.listdir(charts_dir)
        if f.endswith('.xml')
    ]

    if not chart_files:
        print("ℹ️  No charts found — nothing to verify")
        return True

    print(f"\n{'='*60}")
    print(f"  Chart Copy Verifier")
    print(f"  Found {len(chart_files)} chart file(s)")
    print(f"{'='*60}\n")

    all_ok = True

    for chart_file in sorted(chart_files):
        print(f"  📊 {chart_file}")
        chart_ok = True

        # ── 1. Chart XML has declaration ──────────────────────
        chart_path = os.path.join(charts_dir, chart_file)
        with open(chart_path, 'rb') as f:
            header = f.read(60)
        if not header.strip().startswith(b'<?xml'):
            print(f"     ❌ Missing XML declaration")
            chart_ok = False
        else:
            print(f"     ✅ XML declaration present")

        # ── 2. Chart .rels exists ─────────────────────────────
        rels_file = os.path.join(rels_dir, chart_file + '.rels')
        if not os.path.exists(rels_file):
            print(f"     ❌ Missing .rels file")
            chart_ok = False
            all_ok   = False
            continue
        else:
            print(f"     ✅ .rels file exists")

        # ── 3. Parse .rels and check every target exists ──────
        try:
            rels_root = etree.parse(rels_file).getroot()
        except Exception as e:
            print(f"     ❌ Cannot parse .rels: {e}")
            chart_ok = False
            all_ok   = False
            continue

        for rel in rels_root:
            target = rel.get('Target', '')
            mode   = rel.get('TargetMode', '')
            rtype  = rel.get('Type', '').split('/')[-1]

            if mode == 'External' or not target:
                continue

            dep_path = os.path.normpath(
                os.path.join(charts_dir, target)
            )

            if not os.path.exists(dep_path):
                print(f"     ❌ Missing dep [{rtype}]: {target}")
                chart_ok = False
                all_ok   = False
            else:
                # ── 4. Each dep XML has declaration ───────────
                if dep_path.endswith('.xml'):
                    with open(dep_path, 'rb') as f:
                        dep_header = f.read(60)
                    if not dep_header.strip().startswith(b'<?xml'):
                        print(
                            f"     ❌ Dep missing declaration"
                            f" [{rtype}]: {target}"
                        )
                        chart_ok = False
                        all_ok   = False
                    else:
                        print(f"     ✅ Dep OK [{rtype}]: "
                              f"{os.path.basename(target)}")
                else:
                    print(f"     ✅ Dep OK [{rtype}]: "
                          f"{os.path.basename(target)}")

        if chart_ok:
            print(f"     ── Result: ✅ CLEAN\n")
        else:
            print(f"     ── Result: ❌ CORRUPT DEPS\n")
            all_ok = False

    # ── Summary ───────────────────────────────────────────────
    print(f"{'='*60}")
    if all_ok:
        print(f"  ✅ ALL CHARTS OK — safe to save()")
    else:
        print(f"  ❌ CHART ISSUES FOUND — fix before save()")
    print(f"{'='*60}\n")

    return all_ok


# ─────────────────────────────────────────────────────────────
# FULL PIPELINE TEST
# Copy this exactly and run it to test end to end
# ─────────────────────────────────────────────────────────────

def test_chart_copy(model_doc_path, val_report_path, section_name):
    """
    End to end test of chart copying.

    Args:
        model_doc_path  : path to your ModelDoc .docx
        val_report_path : path to your ValReport .docx
        section_name    : section to copy e.g. '3.1 Performance'

    Usage:
        test_chart_copy(
            model_doc_path  = r"C:\docs\model.docx",
            val_report_path = r"C:\docs\val_report.docx",
            section_name    = "3.1 Model Performance"
        )
    """
    print(f"\n{'='*60}")
    print(f"  FULL CHART COPY TEST")
    print(f"  Section : {section_name}")
    print(f"{'='*60}\n")

    # ── Step 1: Open docs ─────────────────────────────────────
    print("  Step 1: Opening documents ... ", end='', flush=True)
    try:
        model = ModelDoc(model_doc_path)
        val   = ValReport(val_report_path)
        print("✅")
    except Exception as e:
        print(f"❌\n  Error: {e}")
        return False

    # ── Step 2: Copy section ──────────────────────────────────
    print("  Step 2: Copying section  ... ", end='', flush=True)
    try:
        title, content = model.copy_content(section_name)
        if not content['data']:
            print(f"❌\n  No content found for '{section_name}'")
            return False
        print(f"✅ ({len(content['data'])} elements, "
              f"{len(content['rels'])} rels)")
    except Exception as e:
        print(f"❌\n  Error: {e}")
        return False

    # ── Step 3: Check chart rels collected ────────────────────
    print("  Step 3: Chart rels found ... ", end='', flush=True)
    chart_rels = [
        r for r in content['rels']
        if r.get('type') == 'chart'
    ]
    if not chart_rels:
        print("ℹ️  No charts in this section")
    else:
        print(f"✅ ({len(chart_rels)} chart(s))")
        for cr in chart_rels:
            src = cr.get('source', 'unknown')
            print(f"     • {os.path.basename(src)}")

    # ── Step 4: Paste content ─────────────────────────────────
    print("  Step 4: Pasting content  ... ", end='', flush=True)
    try:
        val.paste_content(content, after='team response', index='99')
        print("✅")
    except Exception as e:
        print(f"❌\n  Error: {e}")
        return False

    # ── Step 5: Verify chart deps ─────────────────────────────
    print("\n  Step 5: Verifying chart deps:")
    deps_ok = verify_chart_copy(val._path)

    # ── Step 6: Validate XML ──────────────────────────────────
    print("\n  Step 6: XML validation:")
    val.validate_xml_parts()

    # ── Step 7: Save ──────────────────────────────────────────
    print("\n  Step 7: Saving ... ", end='', flush=True)
    try:
        out_path = val_report_path.replace('.docx', '_TEST_OUTPUT.docx')
        val.save(out_path)
        print(f"✅\n  Saved: {out_path}")
    except Exception as e:
        print(f"❌\n  Error: {e}")
        return False

    # ── Step 8: Final check ───────────────────────────────────
    print("\n  Step 8: Final file check ... ", end='', flush=True)
    ok, reason = will_word_open(out_path)
    if ok:
        print(f"✅ PASS — Word will open this file")
    else:
        print(f"❌ FAIL — {reason}")

    print(f"\n{'='*60}")
    print(f"  Result: {'✅ ALL PASSED' if ok and deps_ok else '❌ ISSUES FOUND'}")
    print(f"{'='*60}\n")

    return ok and deps_ok


# ─────────────────────────────────────────────────────────────
# USAGE — paste your paths and run
