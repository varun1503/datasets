    # ------------------------------------------------------------------
    # Paste a block of content after a named anchor paragraph
    # ------------------------------------------------------------------

    def paste_content(self, content, after, index):
        """
        Insert *content['data']* paragraphs after the anchor paragraph.
        Aggressively sanitizes the XML to prevent corruption when skipping
        styles, lists, and relationship updates.
        """
        self.move_cursor(to=after)
        if self._cursor is None:
            return

        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')

        for c in content['data']:
            # 1. STRIP IMAGES & CHARTS (Deletes the tag and its contents)
            etree.strip_elements(c, f'{{{w}}}drawing', with_tail=False)
            etree.strip_elements(c, f'{{{w}}}pict', with_tail=False)

            # 2. STRIP STYLES (Forces text to inherit the destination's default style)
            etree.strip_elements(c, f'{{{w}}}pStyle', with_tail=False)
            etree.strip_elements(c, f'{{{w}}}rStyle', with_tail=False)

            # 3. STRIP LISTS & NUMBERING (Prevents missing numId crashes)
            etree.strip_elements(c, f'{{{w}}}numPr', with_tail=False)

            # 4. STRIP BOOKMARKS (Duplicate bookmark IDs across documents cause instant corruption)
            etree.strip_elements(c, f'{{{w}}}bookmarkStart', with_tail=False)
            etree.strip_elements(c, f'{{{w}}}bookmarkEnd', with_tail=False)

            # 5. STRIP HYPERLINKS BUT KEEP THE TEXT
            # We use `strip_tags` here instead of `strip_elements`. This removes the 
            # <w:hyperlink> wrapper (which contains the corrupting rId) but keeps the 
            # <w:r> text inside so you don't lose words.
            etree.strip_tags(c, f'{{{w}}}hyperlink')

            self._cursor.addnext(c)
            self._cursor = self._cursor.getnext()

        # If you want a purely "simple" paste, you actually don't need to run 
        # update_styles or update_numbering anymore because we stripped them above.
        # You can comment these out if you are completely skipping them:
        # self.update_styles(content)
        # self.update_numbering(content, index)
        
        self.put_relationships(content, index) 
        self.update_index(content, index)

        etree.ElementTree(self._doc).write(
            os.path.join(self._path, 'word', 'document.xml'),
            **_XML_WRITE_KWARGS,
        )
