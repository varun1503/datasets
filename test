    # HELPER — rewrite copied XML file with declaration
    # Fixes colors1.xml, style1.xml etc copied as raw bytes
    # ─────────────────────────────────────────────────────────
    def _rewrite_with_declaration(self, path):
        try:
            tree = etree.parse(path)
            tree.write(
                path,
                xml_declaration=True,
                encoding='UTF-8',
                standalone=True,
                pretty_print=True,
            )
        except Exception as e:
            print(f"  ⚠️  Could not rewrite {path}: {e}")

