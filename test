## Step 3: Retrieval — Return the Right Thing Per Type

```python
retriever = vectorstore.as_retriever(search_kwargs={"k": 5})

def retrieve_and_render(query: str):
    results = retriever.invoke(query)

    for r in results:
        t = r.metadata["type"]
        print(f"\n[{t.upper()}] Section: {r.metadata['section']}")

        if t == "text":
            print(r.page_content)

        elif t == "table":
            # Send raw_table to UI for proper rendering
            print(r.metadata["raw_table"])

        elif t == "image":
            # Send image_ref to UI to load image
            print(f"Image path: {r.metadata['image_ref']}")

retrieve_and_render("What is the GMS exposure limit for small merchants?")
```

