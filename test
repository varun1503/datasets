    # ------------------------------------------------------------------
    # MAIN 2: Paste with Media (Now with Bookmark/Hyperlink safety)
    # ------------------------------------------------------------------
    def paste_content_with_media(self, content, after, index):
        """
        Pastes exact XML but strictly remaps media IDs to prevent corruption.
        Safely removes Bookmarks and Hyperlinks which are silent corruptors.
        """
        self.move_cursor(to=after)
        if self._cursor is None:
            return

        # Get the WordprocessingML namespace
        w = self._doc.nsmap.get('w', 'http://schemas.openxmlformats.org/wordprocessingml/2006/main')

        for c in content['data']:
            # --- THE NEW SAFETY CHECKS ---
            
            # 1. Strip Bookmarks (Prevents integer ID collisions across documents)
            etree.strip_elements(c, f'{{{w}}}bookmarkStart', with_tail=False)
            etree.strip_elements(c, f'{{{w}}}bookmarkEnd', with_tail=False)
            
            # 2. Strip Hyperlinks (Removes the broken rId requirement, but keeps the text)
            etree.strip_tags(c, f'{{{w}}}hyperlink')

            # -----------------------------

            # Remap the image/chart IDs before pasting
            safe_c = self._remap_media_ids(c, index)
            
            self._cursor.addnext(safe_c)
            self._cursor = safe_c

        # IMPORTANT: Make sure your put_relationships function is still in your 
        # class! We need it for the images and charts to actually load!
        self.put_relationships(content, index)  
        self.update_styles(content)
        self.update_numbering(content, index)
        self.update_index(content, index)

        etree.ElementTree(self._doc).write(
            os.path.join(self._path, 'word', 'document.xml'),
            **_XML_WRITE_KWARGS,
        )
