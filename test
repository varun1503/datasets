safe_write(idxdoc,    os.path.join(self._path, '[Content_Types].xml'))
safe_write(stdoc,     os.path.join(self._path, 'word', 'styles.xml'))
safe_write(reldoc,    os.path.join(self._path, 'word', '_rels', 'document.xml.rels'))
safe_write(self._doc, os.path.join(self._path, 'word', 'document.xml'))
```

