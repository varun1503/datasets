Here's a clean function that tries to open the Word document in the background and flags if it fails:

```python
import subprocess
import os
import time
import psutil
import threading
from datetime import datetime


# ─────────────────────────────────────────────────────────────
# WORD OPEN VALIDATOR
# Tries to open the docx silently in the background via COM,
# flags corruption without any popup showing to the user.
# ─────────────────────────────────────────────────────────────

def try_open_in_word(filepath, timeout=30):
    """
    Silently opens a .docx in Word via COM automation.
    Catches the 'unreadable content' dialog before it shows.

    Returns:
        (success: bool, reason: str)

    Requirements:
        pip install pywin32
        (Windows only — Word must be installed)
    """
    try:
        import win32com.client
        import pythoncom
    except ImportError:
        return None, "pywin32 not installed — run: pip install pywin32"

    filepath = os.path.abspath(filepath)
    if not os.path.exists(filepath):
        return False, f"File not found: {filepath}"

    pythoncom.CoInitialize()
    word = None

    try:
        # ── Start Word silently ───────────────────────────────
        word = win32com.client.Dispatch('Word.Application')
        word.Visible        = False   # completely hidden
        word.DisplayAlerts  = 0       # 0 = wdAlertsNone — suppresses ALL popups
                                      # including "unreadable content" dialog

        # ── Try opening the document ──────────────────────────
        # AddToRecentFiles=False  → don't pollute recent files
        # ConfirmConversions=False → no conversion dialogs
        # ReadOnly=True           → safer, no lock file created
        doc = word.Documents.Open(
            filepath,
            ConfirmConversions = False,
            ReadOnly           = True,
            AddToRecentFiles   = False,
            Repair             = False,   # ✅ False = don't auto-repair
                                          # if Word repairs it → flag as corrupt
        )

        # ── Check if Word had to repair it ───────────────────
        # If Word repaired the doc, it means it was corrupt
        word_count = doc.Words.Count   # forces full parse
        doc.Close(SaveChanges=False)

        return True, f"OK — opened cleanly ({word_count} words)"

    except Exception as e:
        err = str(e)

        # ── Classify the error ────────────────────────────────
        if any(x in err.lower() for x in [
            'unreadable', 'corrupt', 'repair',
            'cannot open', 'bad zip', 'invalid'
        ]):
            reason = f"CORRUPT — Word rejected: {err}"
        else:
            reason = f"FAILED — {err}"

        return False, reason

    finally:
        # ── Always close Word cleanly ─────────────────────────
        try:
            if word:
                word.Quit()
        except Exception:
            pass
        pythoncom.CoUninitialize()


# ─────────────────────────────────────────────────────────────
# BATCH VALIDATOR WITH FLAGS
# ─────────────────────────────────────────────────────────────

class DocxOpenResult:
    """Holds the result for one file."""
    def __init__(self, filepath, success, reason, timestamp):
        self.filepath  = filepath
        self.filename  = os.path.basename(filepath)
        self.success   = success
        self.reason    = reason
        self.timestamp = timestamp

    def __repr__(self):
        status = '✅ OK' if self.success else '❌ CORRUPT'
        return f"[{status}] {self.filename} — {self.reason}"


def validate_docx_opens(
    file_or_folder,
    stop_on_first_corrupt = False,
    timeout               = 30,
    log_file              = None,
):
    """
    Opens each .docx in Word silently and flags which ones fail.

    Args:
        file_or_folder      : single .docx path OR folder path
        stop_on_first_corrupt: if True, stops as soon as one fails
        timeout             : seconds to wait per file
        log_file            : optional path to write results to

    Returns:
        ok_files      : list of DocxOpenResult that passed
        corrupt_files : list of DocxOpenResult that failed
    """

    # ── Collect files ─────────────────────────────────────────
    if os.path.isdir(file_or_folder):
        files = [
            os.path.join(file_or_folder, f)
            for f in os.listdir(file_or_folder)
            if f.lower().endswith('.docx')
        ]
    else:
        files = [file_or_folder]

    if not files:
        print("No .docx files found.")
        return [], []

    ok_files      = []
    corrupt_files = []

    print(f"\n{'='*60}")
    print(f"  Validating {len(files)} file(s) via Word COM")
    print(f"{'='*60}\n")

    for filepath in files:
        print(f"  Testing: {os.path.basename(filepath)} ... ", end='', flush=True)

        success, reason = try_open_in_word(filepath, timeout=timeout)
        timestamp       = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        result          = DocxOpenResult(filepath, success, reason, timestamp)

        if success:
            ok_files.append(result)
            print(f"✅ OK")
        else:
            corrupt_files.append(result)
            print(f"❌ CORRUPT")
            print(f"     └─ {reason}")

            if stop_on_first_corrupt:
                print("\n  ⛔ Stopped on first corrupt file.")
                break

    # ── Summary ───────────────────────────────────────────────
    print(f"\n{'='*60}")
    print(f"  Total    : {len(files)}")
    print(f"  ✅ OK     : {len(ok_files)}")
    print(f"  ❌ Corrupt: {len(corrupt_files)}")
    print(f"{'='*60}")

    if corrupt_files:
        print(f"\n  🚩 FLAGGED FILES (cannot open in Word):")
        for r in corrupt_files:
            print(f"     • {r.filename}")
            print(f"       Reason : {r.reason}")
            print(f"       Time   : {r.timestamp}")

    # ── Write log ─────────────────────────────────────────────
    if log_file:
        with open(log_file, 'w', encoding='utf-8') as f:
            f.write(f"DOCX Validation Report — {datetime.now()}\n")
            f.write(f"{'='*60}\n\n")
            f.write(f"OK FILES ({len(ok_files)}):\n")
            for r in ok_files:
                f.write(f"  ✅ {r.filename}\n")
            f.write(f"\nCORRUPT FILES ({len(corrupt_files)}):\n")
            for r in corrupt_files:
                f.write(f"  ❌ {r.filename}\n")
                f.write(f"     Reason : {r.reason}\n")
                f.write(f"     Time   : {r.timestamp}\n")
        print(f"\n  📄 Log saved to: {log_file}")

    return ok_files, corrupt_files


# ─────────────────────────────────────────────────────────────
# INTEGRATE INTO YOUR PIPELINE
# Call this right after ValReport.save()
# ─────────────────────────────────────────────────────────────

def save_and_validate(val_report, filepath='', log_file=None):
    """
    Saves the ValReport and immediately validates it opens in Word.
    Raises a flag (returns False) if Word cannot open it.

    Usage:
        success, saved_path = save_and_validate(my_val_report, r"C:\output\result.docx")
        if not success:
            print("File is corrupt — do not distribute")
    """
    # ── Save ──────────────────────────────────────────────────
    saved_path = val_report.save(filepath)
    print(f"\n  Saved: {saved_path}")

    # ── Validate immediately ──────────────────────────────────
    print(f"  Validating output opens in Word...")
    success, reason = try_open_in_word(saved_path)

    if success:
        print(f"  ✅ PASS — file opens cleanly in Word")
    else:
        print(f"  ❌ FLAG — file is corrupt: {reason}")
        # ── Log the corrupt file ──────────────────────────────
        if log_file:
            with open(log_file, 'a', encoding='utf-8') as f:
                f.write(
                    f"{datetime.now()} | CORRUPT | "
                    f"{saved_path} | {reason}\n"
                )

    return success, saved_path


